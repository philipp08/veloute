    "custom_liquid_8nbTWr": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<style>\n  /* Schriftart 'Red Hat Text' laden */\n  @import url('https://fonts.googleapis.com/css2?family=Red+Hat+Text:wght@300;400;500&display=swap');\n\n  /* Container mit \"Breakout\"-Logik für volle Breite */\n  .necklace-hero-wrapper {\n    position: relative;\n    width: 100vw; /* Volle Bildschirmbreite */\n    left: 50%;\n    right: 50%;\n    margin-left: -50vw;\n    margin-right: -50vw;\n    \n    height: 80vh; /* Höhe des Banners */\n    min-height: 500px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    overflow: hidden;\n    text-align: center;\n    color: #ffffff;\n  }\n\n  /* Hintergrundbild */\n  .necklace-bg-image {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    z-index: 0;\n  }\n\n  /* Dunkles Overlay */\n  .necklace-overlay {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background: rgba(0, 0, 0, 0.25); /* Leichtes Overlay, damit Text lesbar bleibt */\n    z-index: 1;\n  }\n\n  /* Inhalt */\n  .necklace-content {\n    position: relative;\n    z-index: 2;\n    padding: 0 20px;\n    max-width: 800px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n\n  /* Übertitel */\n  .necklace-subtitle {\n    display: block;\n    font-size: 0.75rem;\n    letter-spacing: 0.2em;\n    text-transform: uppercase;\n    margin-bottom: 1.5rem;\n    font-family: 'Red Hat Text', sans-serif; \n    opacity: 0.95;\n    /* Schatten für bessere Lesbarkeit auf hellem Bild */\n    text-shadow: 0 2px 8px rgba(0,0,0,0.4);\n  }\n\n  /* Haupttitel - Elegant & Kursiv */\n  .necklace-title {\n    font-size: 3.5rem;\n    font-weight: 400;\n    margin: 0 0 2.5rem 0;\n    line-height: 1.1;\n    font-family: \"Times New Roman\", Times, serif; \n    font-style: italic;\n    /* Schatten für bessere Lesbarkeit */\n    text-shadow: 0 2px 8px rgba(0,0,0,0.4);\n  }\n\n  /* Button Anpassungen */\n  .necklace-btn {\n    display: inline-block;\n    \n    /* GRÖSSE: Kompakt */\n    padding: 12px 32px;\n    font-size: 0.8rem;\n    \n    background-color: #FFFFFF;\n    color: #000000;\n    text-decoration: none;\n    border: none;\n    border-radius: 0px; /* Eckig */\n    \n    font-family: 'Red Hat Text', sans-serif;\n    font-weight: 400;    /* Dünne Schrift */\n    \n    /* ABSTAND: Ganz eng */\n    letter-spacing: 0;\n    text-transform: uppercase;\n    \n    transition: all 0.3s ease;\n    cursor: pointer;\n    box-shadow: 0 4px 15px rgba(0,0,0,0.2);\n  }\n\n  .necklace-btn:hover {\n    background-color: #F0F0F0;\n    transform: translateY(-2px);\n  }\n\n  /* Mobile Anpassung */\n  @media (max-width: 768px) {\n    .necklace-hero-wrapper {\n      height: 60vh;\n    }\n    .necklace-title {\n      font-size: 2.2rem;\n    }\n    .necklace-btn {\n      padding: 10px 25px;\n      font-size: 0.75rem;\n    }\n  }\n</style>\n\n<div class=\"necklace-hero-wrapper\">\n  <!-- DEIN NEUES BILD -->\n  <img \n    src=\"https://i.ibb.co/wNBChXPQ/Gemini-Generated-Image-1htmmz1htmmz1htm.jpg\" \n    alt=\"Halsketten Kollektion\" \n    class=\"necklace-bg-image\"\n  >\n\n  <div class=\"necklace-overlay\"></div>\n\n  <div class=\"necklace-content\">\n    <span class=\"necklace-subtitle\">JETZT NEU</span>\n    <h2 class=\"necklace-title\">Die Kollektion Privé</h2>\n    <a href=\"/collections/all\" class=\"necklace-btn\">JETZT ENTDECKEN</a>\n  </div>\n</div>",
        "color_scheme": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "custom_liquid_mjYgAw": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "{% comment %}\n  Version 20: \n  - Design: Minimalistisch (ohne Pinselstrich).\n  - Pfeil: Weißes Icon (#ffffff) auf schwarzem Grund (#000000).\n  - Funktion: Intelligente Pfeile & Dynamischer Footer-Link.\n{% endcomment %}\n\n{% assign heading_small = \"UNSERE BESTSELLER\" %}\n\n{% comment %} KOLLEKTIONEN {% endcomment %}\n{% assign cat_1_title = \"Halsketten\" %}\n{% assign cat_1_handle = \"halsketten\" %}\n\n{% assign cat_2_title = \"Armbänder\" %}\n{% assign cat_2_handle = \"armbaender\" %}\n\n{% assign cat_3_title = \"Schlüsselanhänger\" %}\n{% assign cat_3_handle = \"schlusselanhanger\" %}\n\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Red+Hat+Text:wght@400;500;600&display=swap');\n\n  .bestseller-tabs-block { padding: 40px 0; overflow: hidden; position: relative; }\n  .bestseller-header { text-align: center; margin-bottom: 30px; }\n  .bestseller-eyebrow { font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 10px; display: block; font-weight: 600; color: #333; }\n  \n  .bestseller-nav { display: flex; justify-content: center; gap: 20px; flex-wrap: wrap; margin-bottom: 20px; }\n  @media screen and (max-width: 749px) { .bestseller-nav { gap: 10px; row-gap: 2px; } }\n\n  .tab-btn { background: none; border: none; font-size: 26px; cursor: pointer; color: #ccc; transition: all 0.3s; padding: 0 5px; font-family: 'Red Hat Text', sans-serif; font-weight: 400; line-height: 1.2; }\n  .tab-btn.active { color: #000; font-weight: 500; }\n  .tab-btn:hover { color: #666; }\n\n  .tab-content { display: none; }\n  .tab-content.active { display: block; animation: fadeIn 0.5s; }\n  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }\n\n  .slider-container { position: relative; max-width: 1600px; margin: 0 auto; padding: 0 20px; }\n  .product-slider { display: flex; overflow-x: auto; gap: 20px; scroll-snap-type: x mandatory; padding-bottom: 20px; -ms-overflow-style: none; scrollbar-width: none; scroll-behavior: smooth; }\n  .product-slider::-webkit-scrollbar { display: none; }\n  .slider-item { flex: 0 0 70%; scroll-snap-align: start; min-width: 0; }\n  @media screen and (max-width: 749px) { .slider-item:nth-child(n+7) { display: none; } }\n\n  /* NAVIGATION BUTTONS */\n  .slider-arrow {\n    position: absolute; top: 35%; transform: translateY(-50%); width: 44px; height: 44px;\n    background-color: #000000 !important; border: none; border-radius: 50%; cursor: pointer; z-index: 2;\n    display: none; align-items: center; justify-content: center;\n    transition: opacity 0.3s ease, transform 0.2s, background 0.2s; opacity: 0; pointer-events: none;\n  }\n  .slider-arrow.visible { opacity: 1; pointer-events: auto; }\n  .slider-arrow:hover { transform: translateY(-50%) scale(1.1); background-color: #333333 !important; }\n  \n  /* PFEIL ICON (WEISS) */\n  .slider-arrow svg { width: 20px; height: 20px; fill: none; display: block; }\n  .slider-arrow svg path { stroke: #ffffff !important; stroke-width: 1.2; }\n  \n  .arrow-prev { left: 10px; }\n  .arrow-next { right: 10px; }\n\n  @media(min-width: 750px) { .slider-item { flex: 0 0 40%; } .slider-arrow { display: flex; } }\n  @media(min-width: 990px) { .slider-item { flex: 0 0 24%; } }\n\n  .simple-card { text-decoration: none; color: inherit; display: block; }\n  .card-image-wrapper { position: relative; width: 100%; padding-top: 125%; overflow: hidden; background: #f4f4f4; border-radius: 4px; margin-bottom: 10px; }\n  .card-image { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }\n  .simple-card:hover .card-image { transform: scale(1.05); }\n  .card-info { text-align: left; }\n  .card-title { font-size: 1rem; margin: 0 0 5px; font-weight: 500; color: #000; font-family: 'Red Hat Text', sans-serif; }\n  .card-price { font-size: 0.9rem; color: #555; font-family: 'Red Hat Text', sans-serif; }\n\n  /* VIEW ALL LINKS */\n  .view-all-wrapper { text-align: center; margin-top: 30px; padding-bottom: 10px; }\n  .view-all-btn { display: none; font-family: 'Red Hat Text', sans-serif; font-size: 0.9rem; text-transform: uppercase; text-decoration: none; color: #000; border-bottom: 1px solid #000; padding-bottom: 2px; letter-spacing: 0.05em; transition: opacity 0.3s; }\n  .view-all-btn.active { display: inline-block; animation: fadeIn 0.5s; }\n  .view-all-btn:hover { color: #555; border-bottom-color: #555; }\n</style>\n\n<div class=\"bestseller-tabs-block page-width\">\n  <div class=\"bestseller-header\">\n    <span class=\"bestseller-eyebrow\">{{ heading_small }}</span>\n    <div class=\"bestseller-nav\">\n      <button class=\"tab-btn active\" data-tab=\"1\">{{ cat_1_title }}</button>\n      <button class=\"tab-btn\" data-tab=\"2\">{{ cat_2_title }}</button>\n      <button class=\"tab-btn\" data-tab=\"3\">{{ cat_3_title }}</button>\n    </div>\n  </div>\n\n  {% assign handles = cat_1_handle | append: ',' | append: cat_2_handle | append: ',' | append: cat_3_handle | split: ',' %}\n  \n  {% for handle in handles %}\n    {% assign i = forloop.index %}\n    <div data-content=\"{{ i }}\" class=\"tab-content {% if i == 1 %}active{% endif %}\">\n      <div class=\"slider-container\">\n        \n        <button class=\"slider-arrow arrow-prev\" aria-label=\"Zurück\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\">\n            <path d=\"M19 12H5M5 12L11 18M5 12L11 6\" stroke=\"#ffffff\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n        </button>\n\n        <div class=\"product-slider\" id=\"slider-{{ i }}\">\n          {% assign target_collection = collections[handle] %}\n          \n          {% if target_collection.products.size > 0 %}\n            {% for product in target_collection.products limit: 8 %}\n              <div class=\"slider-item\">\n                <a href=\"{{ product.url }}\" class=\"simple-card\">\n                  <div class=\"card-image-wrapper\">\n                    {% if product.featured_image != blank %}\n                      <img class=\"card-image\" src=\"{{ product.featured_image | image_url: width: 600 }}\" loading=\"lazy\" width=\"{{ product.featured_image.width }}\" height=\"{{ product.featured_image.height }}\" alt=\"{{ product.title | escape }}\">\n                    {% else %}\n                      {{ 'product-1' | placeholder_svg_tag: 'card-image' }}\n                    {% endif %}\n                  </div>\n                  <div class=\"card-info\">\n                    <h3 class=\"card-title\">{{ product.title }}</h3>\n                    <span class=\"card-price\">{{ product.price | money }}</span>\n                  </div>\n                </a>\n              </div>\n            {% endfor %}\n          {% else %}\n             <div style=\"width:100%; text-align:center; padding: 40px 15px;\">\n                <p>Kollektion leer.</p>\n             </div>\n          {% endif %}\n        </div>\n\n        <button class=\"slider-arrow arrow-next\" aria-label=\"Weiter\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\">\n            <path d=\"M5 12H19M19 12L13 18M19 12L13 6\" stroke=\"#ffffff\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n        </button>\n      </div>\n    </div>\n  {% endfor %}\n\n  <!-- VIEW ALL BUTTONS -->\n  <div class=\"view-all-wrapper\">\n    <a href=\"/collections/{{ cat_1_handle }}\" class=\"view-all-btn active\" data-link=\"1\">Alle {{ cat_1_title }} anzeigen</a>\n    <a href=\"/collections/{{ cat_2_handle }}\" class=\"view-all-btn\" data-link=\"2\">Alle {{ cat_2_title }} anzeigen</a>\n    <a href=\"/collections/{{ cat_3_handle }}\" class=\"view-all-btn\" data-link=\"3\">Alle {{ cat_3_title }} anzeigen</a>\n  </div>\n</div>\n\n<script>\n  if (!window.bestsellerTabInit) {\n    window.bestsellerTabInit = true;\n\n    function checkArrows(slider) {\n      const container = slider.parentElement;\n      const prevBtn = container.querySelector('.arrow-prev');\n      const nextBtn = container.querySelector('.arrow-next');\n      if (!prevBtn || !nextBtn) return;\n      const tolerance = 2;\n      const maxScroll = slider.scrollWidth - slider.clientWidth;\n\n      if (slider.scrollLeft > tolerance) {\n        prevBtn.classList.add('visible');\n      } else {\n        prevBtn.classList.remove('visible');\n      }\n\n      if (slider.scrollLeft >= maxScroll - tolerance) {\n        nextBtn.classList.remove('visible');\n      } else {\n        nextBtn.classList.add('visible');\n      }\n    }\n\n    document.body.addEventListener('click', function(evt) {\n      if (evt.target.matches('.tab-btn')) {\n        const btn = evt.target;\n        const block = btn.closest('.bestseller-tabs-block');\n        if (!block) return;\n        const tabNum = btn.getAttribute('data-tab');\n        \n        block.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));\n        btn.classList.add('active');\n\n        block.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));\n        const content = block.querySelector(`.tab-content[data-content=\"${tabNum}\"]`);\n        if (content) {\n          content.classList.add('active');\n          const slider = content.querySelector('.product-slider');\n          if(slider) setTimeout(() => checkArrows(slider), 50);\n        }\n\n        block.querySelectorAll('.view-all-btn').forEach(link => link.classList.remove('active'));\n        const activeLink = block.querySelector(`.view-all-btn[data-link=\"${tabNum}\"]`);\n        if (activeLink) activeLink.classList.add('active');\n      }\n\n      const btn = evt.target.closest('.slider-arrow');\n      if (btn) {\n        const container = btn.closest('.slider-container');\n        const slider = container.querySelector('.product-slider');\n        const itemWidth = slider.querySelector('.slider-item').offsetWidth;\n        const gap = 20; \n        const scrollAmount = itemWidth + gap;\n        if (btn.classList.contains('arrow-next')) {\n          slider.scrollBy({ left: scrollAmount, behavior: 'smooth' });\n        } else {\n          slider.scrollBy({ left: -scrollAmount, behavior: 'smooth' });\n        }\n      }\n    });\n\n    const allSliders = document.querySelectorAll('.product-slider');\n    allSliders.forEach(slider => {\n      slider.addEventListener('scroll', () => checkArrows(slider));\n      checkArrows(slider);\n    });\n    window.addEventListener('resize', () => { allSliders.forEach(slider => checkArrows(slider)); });\n  }\n</script>",
