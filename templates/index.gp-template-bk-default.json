            "custom_liquid": "<style>\n  /* Schriftart */\n  @import url('https://fonts.googleapis.com/css2?family=Red+Hat+Text:wght@300;400;500&display=swap');\n\n  /* Container */\n  .veloute-btn-wrapper {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    gap: 15px;\n    padding: 25px 0;\n    width: 100%;\n    box-sizing: border-box;\n  }\n\n  /* Button Basis - Elegant */\n  .veloute-btn {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    \n    /* Maße Mobil */\n    width: 80%;\n    min-width: 200px;\n    max-width: 350px;\n    padding: 14px 0; /* Etwas mehr Höhe für Eleganz */\n    \n    /* Typografie - Edel */\n    font-family: 'Red Hat Text', sans-serif;\n    font-size: 0.8rem; /* Etwas kleiner, dafür mehr Abstand */\n    font-weight: 400;\n    letter-spacing: 0.15em; /* Weite Buchstabenabstände = Elegant */\n    text-transform: uppercase;\n    text-decoration: none;\n    \n    /* Form */\n    border-radius: 0px;\n    transition: all 0.4s ease; /* Langsamere Transition wirkt ruhiger */\n    cursor: pointer;\n    box-sizing: border-box;\n    \n    /* Backdrop Filter für Glas-Effekt (optional, wirkt sehr modern) */\n    backdrop-filter: blur(2px);\n  }\n\n  /* --- DAMEN (Hell) --- */\n  .btn-damen {\n    /* Leicht transparenter weißer Hintergrund */\n    background-color: rgba(255, 255, 255, 0.9); \n    color: #1a1a1a; /* Kein hartes Schwarz, sondern dunkles Grau */\n    border: 1px solid rgba(255, 255, 255, 0.0); /* Unsichtbarer Border für Layout-Stabilität */\n  }\n  \n  .btn-damen:hover {\n    background-color: rgba(255, 255, 255, 1); /* Volle Deckkraft beim Hover */\n    transform: translateY(-2px); /* Leichtes Schweben */\n    box-shadow: 0 5px 15px rgba(255, 255, 255, 0.3); /* Sanfter Glow */\n    letter-spacing: 0.2em; /* Buchstaben weiten sich leicht beim Hover - sehr edel */\n  }\n\n  /* --- HERREN (Dunkel) --- */\n  .btn-herren {\n    /* Leicht transparenter schwarzer Hintergrund */\n    background-color: rgba(0, 0, 0, 0.85); \n    color: #ffffff;\n    border: 1px solid rgba(255, 255, 255, 0.1); /* Ganz feiner heller Rand */\n  }\n  \n  .btn-herren:hover {\n    background-color: #000000;\n    border-color: rgba(255, 255, 255, 0.3);\n    transform: translateY(-2px);\n    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.4);\n    letter-spacing: 0.2em;\n  }\n\n  /* --- DESKTOP --- */\n  @media (min-width: 769px) {\n    .veloute-btn-wrapper {\n      flex-direction: row;\n      gap: 25px;\n    }\n    \n    .veloute-btn {\n      width: 160px; /* Schlank auf Desktop */\n      min-width: unset;\n      padding: 16px 0;\n      font-size: 0.75rem; /* Noch etwas feiner auf großem Screen */\n    }\n  }\n</style>\n\n<div class=\"veloute-btn-wrapper\">\n  <!-- BUTTON DAMEN -->\n  <a href=\"https://velouté-boutique.de/collections/damen-accessoires\" class=\"veloute-btn btn-damen\">\n    DAMEN\n  </a>\n  \n  <!-- BUTTON HERREN -->\n  <a href=\"https://velouté-boutique.de/collections/herren-accessoires\" class=\"veloute-btn btn-herren\">\n    HERREN\n  </a>\n</div>"
