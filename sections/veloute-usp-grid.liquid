<section class="veloute-usp-grid color-{{ section.settings.color_scheme }}">
  <style>
    #shopify-section-{{ section.id }} .veloute-usp-grid {
      background: var(--color-background);
      color: var(--color-foreground);
    }

    #shopify-section-{{ section.id }} .veloute-usp-grid__inner {
      width: min(100% - 32px, 1320px);
      margin: 0 auto;
      padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .veloute-usp-grid__header {
      max-width: 760px;
      margin-bottom: clamp(24px, 4vw, 42px);
    }

    #shopify-section-{{ section.id }} .veloute-usp-grid__header h2 {
      margin: 0;
      font-family: var(--font-heading--family);
      font-size: clamp(2rem, 4vw, 4.6rem);
      line-height: .98;
      font-weight: 500;
      text-wrap: balance;
    }

    #shopify-section-{{ section.id }} .veloute-usp-grid__items {
      display: grid;
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
      gap: 1px;
      background: rgb(var(--color-foreground-rgb) / .13);
      border: 1px solid rgb(var(--color-foreground-rgb) / .13);
    }

    #shopify-section-{{ section.id }} .veloute-usp-grid__item {
      min-height: 178px;
      display: grid;
      align-content: start;
      gap: 12px;
      background: var(--color-background);
      padding: clamp(22px, 3vw, 34px);
    }

    #shopify-section-{{ section.id }} .veloute-usp-grid__item span {
      font-size: .72rem;
      letter-spacing: .12em;
      line-height: 1.25;
      text-transform: uppercase;
      color: rgb(var(--color-foreground-rgb) / .62);
    }

    #shopify-section-{{ section.id }} .veloute-usp-grid__item h3 {
      margin: 0;
      font-size: 1.25rem;
      line-height: 1.25;
      font-weight: 500;
    }

    #shopify-section-{{ section.id }} .veloute-usp-grid__item p {
      margin: 0;
      color: rgb(var(--color-foreground-rgb) / .66);
      line-height: 1.55;
    }

    @media screen and (max-width: 989px) {
      #shopify-section-{{ section.id }} .veloute-usp-grid__items {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .veloute-usp-grid__inner {
        width: min(100% - 28px, 1320px);
      }

      #shopify-section-{{ section.id }} .veloute-usp-grid__items {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="veloute-usp-grid__inner">
    {% if section.settings.heading != blank %}
      <div class="veloute-usp-grid__header">
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="veloute-usp-grid__items">
      {% for block in section.blocks %}
        <div class="veloute-usp-grid__item" {{ block.shopify_attributes }}>
          {% if block.settings.kicker != blank %}
            <span>{{ block.settings.kicker }}</span>
          {% endif %}
          {% if block.settings.heading != blank %}
            <h3>{{ block.settings.heading }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <p>{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Veloute USP grid",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Warum Veloute."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "text",
          "id": "kicker",
          "label": "Small label",
          "default": "01"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Klar kuratiert"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Weniger beliebige Auswahl, mehr schnelle Orientierung."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Veloute USP grid",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
