{{ 'veloute-reveal.css' | asset_url | stylesheet_tag }}
<script src="{{ 'veloute-reveal.js' | asset_url }}" defer></script>

<section class="veloute-lookbook color-{{ section.settings.color_scheme }}">
  <style>
    #shopify-section-{{ section.id }} .veloute-lookbook {
      background: var(--color-background);
      color: var(--color-foreground);
      padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .veloute-lookbook__inner {
      width: min(100% - 32px, 1320px);
      margin: 0 auto;
    }

    #shopify-section-{{ section.id }} .veloute-lookbook__header {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 28px;
      margin-bottom: clamp(28px, 5vw, 56px);
    }

    #shopify-section-{{ section.id }} .veloute-lookbook__eyebrow {
      margin: 0 0 14px;
      font-size: .72rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: rgb(var(--color-foreground-rgb) / .6);
    }

    #shopify-section-{{ section.id }} .veloute-lookbook__heading {
      margin: 0;
      max-width: 760px;
      font-family: var(--font-heading--family);
      font-size: clamp(2.2rem, 4.6vw, 5rem);
      line-height: .98;
      font-weight: 500;
      letter-spacing: -.005em;
    }

    #shopify-section-{{ section.id }} .veloute-lookbook__grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-auto-rows: minmax(120px, auto);
      gap: clamp(8px, 1.2vw, 18px);
    }

    #shopify-section-{{ section.id }} .veloute-lookbook__item {
      position: relative;
      display: block;
      overflow: hidden;
      background: #efece8;
      text-decoration: none;
      color: #fff;
      grid-column: span 6;
      aspect-ratio: 4 / 5;
    }
    #shopify-section-{{ section.id }} .veloute-lookbook__item--wide   { grid-column: span 8; aspect-ratio: 16 / 11; }
    #shopify-section-{{ section.id }} .veloute-lookbook__item--narrow { grid-column: span 4; aspect-ratio: 3 / 4; }
    #shopify-section-{{ section.id }} .veloute-lookbook__item--tall   { grid-column: span 5; aspect-ratio: 3 / 4; }
    #shopify-section-{{ section.id }} .veloute-lookbook__item--medium { grid-column: span 7; aspect-ratio: 7 / 5; }
    #shopify-section-{{ section.id }} .veloute-lookbook__item--square { grid-column: span 6; aspect-ratio: 1 / 1; }

    #shopify-section-{{ section.id }} .veloute-lookbook__item img,
    #shopify-section-{{ section.id }} .veloute-lookbook__item svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 1s cubic-bezier(.2,.7,.2,1);
    }

    #shopify-section-{{ section.id }} .veloute-lookbook__item:hover img {
      transform: scale(1.05);
    }

    #shopify-section-{{ section.id }} .veloute-lookbook__caption {
      position: absolute;
      left: 0; right: 0; bottom: 0;
      padding: clamp(14px, 2vw, 24px);
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 14px;
      background: linear-gradient(0deg, rgb(0 0 0 / .65), rgb(0 0 0 / 0) 70%);
      opacity: 0;
      transform: translateY(8px);
      transition: opacity .4s ease, transform .4s ease;
    }

    #shopify-section-{{ section.id }} .veloute-lookbook__item:hover .veloute-lookbook__caption,
    #shopify-section-{{ section.id }} .veloute-lookbook__item:focus-visible .veloute-lookbook__caption {
      opacity: 1;
      transform: none;
    }

    #shopify-section-{{ section.id }} .veloute-lookbook__caption-title {
      font-size: .92rem;
      line-height: 1.3;
      font-weight: 500;
    }
    #shopify-section-{{ section.id }} .veloute-lookbook__caption-cta {
      font-size: .7rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    @media screen and (max-width: 989px) {
      #shopify-section-{{ section.id }} .veloute-lookbook__item,
      #shopify-section-{{ section.id }} .veloute-lookbook__item--wide,
      #shopify-section-{{ section.id }} .veloute-lookbook__item--narrow,
      #shopify-section-{{ section.id }} .veloute-lookbook__item--tall,
      #shopify-section-{{ section.id }} .veloute-lookbook__item--medium,
      #shopify-section-{{ section.id }} .veloute-lookbook__item--square {
        grid-column: span 6;
      }
    }

    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .veloute-lookbook__header {
        display: grid;
      }
      #shopify-section-{{ section.id }} .veloute-lookbook__item,
      #shopify-section-{{ section.id }} .veloute-lookbook__item--wide,
      #shopify-section-{{ section.id }} .veloute-lookbook__item--narrow,
      #shopify-section-{{ section.id }} .veloute-lookbook__item--tall,
      #shopify-section-{{ section.id }} .veloute-lookbook__item--medium,
      #shopify-section-{{ section.id }} .veloute-lookbook__item--square {
        grid-column: span 12;
        aspect-ratio: 4 / 5;
      }
      #shopify-section-{{ section.id }} .veloute-lookbook__caption {
        opacity: 1; transform: none;
      }
    }
  </style>

  <div class="veloute-lookbook__inner">
    <div class="veloute-lookbook__header">
      <div>
        {% if section.settings.eyebrow != blank %}
          <p class="veloute-lookbook__eyebrow" data-reveal>{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="veloute-lookbook__heading" data-reveal data-reveal-delay="1">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
    </div>

    <div class="veloute-lookbook__grid">
      {% for block in section.blocks %}
        {% liquid
          assign link = block.settings.link | default: routes.all_products_collection_url
          assign size = block.settings.size
        %}
        <a class="veloute-lookbook__item veloute-lookbook__item--{{ size }}" href="{{ link }}" data-reveal data-reveal-delay="{{ forloop.index | modulo: 6 }}" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 1600 | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 990px) 50vw, 100vw',
                widths: '500,800,1100,1400,1800',
                alt: block.settings.title }}
          {% else %}
            {{ 'lifestyle-1' | placeholder_svg_tag }}
          {% endif %}
          {% if block.settings.title != blank or block.settings.cta != blank %}
            <div class="veloute-lookbook__caption">
              {% if block.settings.title != blank %}
                <span class="veloute-lookbook__caption-title">{{ block.settings.title }}</span>
              {% endif %}
              {% if block.settings.cta != blank %}
                <span class="veloute-lookbook__caption-cta">{{ block.settings.cta }} →</span>
              {% endif %}
            </div>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Veloute Lookbook",
  "tag": "section",
  "class": "section-veloute-lookbook",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Lookbook" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "In Szene gesetzt." },
    { "type": "range", "id": "padding_top", "label": "Padding oben", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Padding unten", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 100 }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Bild",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild" },
        {
          "type": "select",
          "id": "size",
          "label": "Größe",
          "options": [
            { "value": "wide",   "label": "Breit (8 col)" },
            { "value": "narrow", "label": "Schmal (4 col)" },
            { "value": "tall",   "label": "Hoch (5 col)" },
            { "value": "medium", "label": "Mittel (7 col)" },
            { "value": "square", "label": "Quadrat (6 col)" }
          ],
          "default": "wide"
        },
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "text", "id": "cta", "label": "CTA-Text", "default": "Shop" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Veloute Lookbook",
      "blocks": [
        { "type": "image", "settings": { "size": "wide",   "title": "Stack & Layer" } },
        { "type": "image", "settings": { "size": "narrow", "title": "Daily Pieces" } },
        { "type": "image", "settings": { "size": "tall",   "title": "Statement" } },
        { "type": "image", "settings": { "size": "medium", "title": "Soft Metals" } },
        { "type": "image", "settings": { "size": "narrow", "title": "Detail" } },
        { "type": "image", "settings": { "size": "wide",   "title": "Editorial" } }
      ]
    }
  ]
}
{% endschema %}
