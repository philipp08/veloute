{% liquid
  assign product_collection = section.settings.collection
  assign product_count = section.settings.product_count
%}

<section class="veloute-featured-products color-{{ section.settings.color_scheme }}">
  <style>
    #shopify-section-{{ section.id }} .veloute-featured-products {
      background: var(--color-background);
      color: var(--color-foreground);
    }

    #shopify-section-{{ section.id }} .veloute-featured-products__inner {
      width: min(100% - 32px, 1320px);
      margin: 0 auto;
      padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .veloute-featured-products__header {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 28px;
      margin-bottom: clamp(22px, 4vw, 40px);
    }

    #shopify-section-{{ section.id }} .veloute-featured-products__header h2 {
      margin: 0;
      font-family: var(--font-heading--family);
      font-size: clamp(2rem, 4vw, 4.6rem);
      line-height: .98;
      font-weight: 500;
      text-wrap: balance;
    }

    #shopify-section-{{ section.id }} .veloute-featured-products__header p {
      margin: 10px 0 0;
      max-width: 560px;
      color: rgb(var(--color-foreground-rgb) / .66);
      line-height: 1.6;
    }

    #shopify-section-{{ section.id }} .veloute-featured-products__view-all {
      color: inherit;
      white-space: nowrap;
      text-decoration: none;
      font-size: .78rem;
      line-height: 1.2;
      letter-spacing: .1em;
      text-transform: uppercase;
      border-bottom: 1px solid currentColor;
      padding-bottom: 4px;
    }

    #shopify-section-{{ section.id }} .veloute-featured-products__grid {
      display: grid;
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
      gap: {{ section.settings.gap }}px;
    }

    #shopify-section-{{ section.id }} .veloute-product-card {
      min-width: 0;
      color: inherit;
      text-decoration: none;
    }

    #shopify-section-{{ section.id }} .veloute-product-card__media {
      position: relative;
      overflow: hidden;
      aspect-ratio: {{ section.settings.image_ratio }};
      background: rgb(var(--color-foreground-rgb) / .045);
    }

    #shopify-section-{{ section.id }} .veloute-product-card__media img,
    #shopify-section-{{ section.id }} .veloute-product-card__media svg {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform .5s ease;
    }

    #shopify-section-{{ section.id }} .veloute-product-card:hover .veloute-product-card__media img,
    #shopify-section-{{ section.id }} .veloute-product-card:hover .veloute-product-card__media svg {
      transform: scale(1.035);
    }

    #shopify-section-{{ section.id }} .veloute-product-card__info {
      display: grid;
      gap: 4px;
      padding-top: 12px;
    }

    #shopify-section-{{ section.id }} .veloute-product-card__title {
      margin: 0;
      font-size: .98rem;
      line-height: 1.32;
      font-weight: 500;
    }

    #shopify-section-{{ section.id }} .veloute-product-card__price {
      color: rgb(var(--color-foreground-rgb) / .68);
      font-size: .9rem;
      line-height: 1.35;
    }

    @media screen and (max-width: 989px) {
      #shopify-section-{{ section.id }} .veloute-featured-products__grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .veloute-featured-products__inner {
        width: min(100% - 28px, 1320px);
      }

      #shopify-section-{{ section.id }} .veloute-featured-products__header {
        display: grid;
      }
    }
  </style>

  <div class="veloute-featured-products__inner">
    <div class="veloute-featured-products__header">
      <div>
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <p>{{ section.settings.text }}</p>
        {% endif %}
      </div>
      {% if section.settings.show_view_all and product_collection != blank %}
        <a class="veloute-featured-products__view-all" href="{{ product_collection.url }}">{{ section.settings.view_all_label }}</a>
      {% endif %}
    </div>

    <div class="veloute-featured-products__grid">
      {% if product_collection != blank and product_collection.products.size > 0 %}
        {% for product in product_collection.products limit: product_count %}
          <a class="veloute-product-card" href="{{ product.url }}">
            <div class="veloute-product-card__media">
              {% if product.featured_image != blank %}
                {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 25vw, 50vw', alt: product.title }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag }}
              {% endif %}
            </div>
            <div class="veloute-product-card__info">
              <p class="veloute-product-card__title">{{ product.title }}</p>
              <span class="veloute-product-card__price">{{ product.price | money }}</span>
            </div>
          </a>
        {% endfor %}
      {% else %}
        {% for i in (1..product_count) %}
          <div class="veloute-product-card">
            <div class="veloute-product-card__media">{{ 'product-1' | placeholder_svg_tag }}</div>
            <div class="veloute-product-card__info">
              <p class="veloute-product-card__title">Produkt auswählen</p>
              <span class="veloute-product-card__price">{{ 2990 | money }}</span>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Veloute products",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Highlights der Woche."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Eine reduzierte Auswahl, die schnell Orientierung gibt und direkt kaufbar ist."
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Product count",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "1 / 1", "label": "Square" },
        { "value": "4 / 5", "label": "Portrait" },
        { "value": "3 / 4", "label": "Tall portrait" }
      ],
      "default": "4 / 5"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "Alle ansehen"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Veloute products"
    }
  ]
}
{% endschema %}
