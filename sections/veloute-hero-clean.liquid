{% liquid
  assign primary_link = section.settings.primary_link
  if primary_link == blank
    assign primary_link = routes.all_products_collection_url
  endif

  assign secondary_link = section.settings.secondary_link
  if secondary_link == blank
    assign secondary_link = routes.all_products_collection_url
  endif
%}

<section class="veloute-hero-clean color-{{ section.settings.color_scheme }}">
  <style>
    #shopify-section-{{ section.id }} .veloute-hero-clean {
      --hero-height-desktop: {{ section.settings.height_desktop }}svh;
      --hero-height-mobile: {{ section.settings.height_mobile }}svh;
      --hero-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
      position: relative;
      min-height: var(--hero-height-desktop);
      display: grid;
      align-items: {{ section.settings.vertical_alignment }};
      overflow: hidden;
      color: #fff;
      background: #111;
      isolation: isolate;
    }

    #shopify-section-{{ section.id }} .veloute-hero-clean__media,
    #shopify-section-{{ section.id }} .veloute-hero-clean__media img,
    #shopify-section-{{ section.id }} .veloute-hero-clean__media video {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    #shopify-section-{{ section.id }} .veloute-hero-clean__media {
      z-index: -2;
      background: #111;
    }

    #shopify-section-{{ section.id }} .veloute-hero-clean__media img,
    #shopify-section-{{ section.id }} .veloute-hero-clean__media video {
      object-fit: cover;
    }

    #shopify-section-{{ section.id }} .veloute-hero-clean::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      background:
        linear-gradient(90deg, rgb(0 0 0 / calc(var(--hero-overlay) + .14)), rgb(0 0 0 / calc(var(--hero-overlay) * .55)) 48%, rgb(0 0 0 / .12)),
        linear-gradient(0deg, rgb(0 0 0 / .52), rgb(0 0 0 / .02) 62%);
    }

    #shopify-section-{{ section.id }} .veloute-hero-clean__inner {
      width: min(100% - 32px, 1320px);
      margin: 0 auto;
      padding: clamp(88px, 11vw, 150px) 0 clamp(38px, 7vw, 88px);
      text-align: {{ section.settings.text_alignment }};
      display: grid;
      justify-items: {% if section.settings.text_alignment == 'center' %}center{% elsif section.settings.text_alignment == 'right' %}end{% else %}start{% endif %};
    }

    #shopify-section-{{ section.id }} .veloute-hero-clean__eyebrow {
      margin: 0 0 18px;
      font-size: .74rem;
      line-height: 1.35;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: rgb(255 255 255 / .82);
    }

    #shopify-section-{{ section.id }} .veloute-hero-clean__heading {
      margin: 0;
      width: min(100%, {{ section.settings.content_width }}px);
      font-family: var(--font-heading--family);
      font-size: clamp(3rem, 7vw, 7.1rem);
      line-height: .92;
      font-weight: 500;
      text-wrap: balance;
    }

    #shopify-section-{{ section.id }} .veloute-hero-clean__text {
      margin: 22px 0 0;
      width: min(100%, 560px);
      color: rgb(255 255 255 / .78);
      font-size: clamp(1rem, 1.25vw, 1.15rem);
      line-height: 1.65;
    }

    #shopify-section-{{ section.id }} .veloute-hero-clean__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 32px;
      justify-content: {% if section.settings.text_alignment == 'center' %}center{% elsif section.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
    }

    #shopify-section-{{ section.id }} .veloute-hero-clean__button {
      min-width: 156px;
      min-height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 22px;
      border: 1px solid currentColor;
      font-size: .78rem;
      line-height: 1.2;
      letter-spacing: .1em;
      text-transform: uppercase;
      text-decoration: none;
      transition: transform .22s ease, background-color .22s ease, border-color .22s ease, color .22s ease;
    }

    #shopify-section-{{ section.id }} .veloute-hero-clean__button:hover {
      transform: translateY(-2px);
    }

    #shopify-section-{{ section.id }} .veloute-hero-clean__button--primary {
      color: #111;
      background: #fff;
      border-color: #fff;
    }

    #shopify-section-{{ section.id }} .veloute-hero-clean__button--secondary {
      color: #fff;
      background: rgb(255 255 255 / .08);
      border-color: rgb(255 255 255 / .5);
      backdrop-filter: blur(8px);
    }

    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .veloute-hero-clean {
        min-height: var(--hero-height-mobile);
      }

      #shopify-section-{{ section.id }} .veloute-hero-clean__inner {
        width: min(100% - 28px, 1320px);
      }

      #shopify-section-{{ section.id }} .veloute-hero-clean__actions,
      #shopify-section-{{ section.id }} .veloute-hero-clean__button {
        width: 100%;
      }
    }
  </style>

  <div class="veloute-hero-clean__media" aria-hidden="true">
    {% if section.settings.video != blank %}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
    {% elsif section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 2800 | image_tag: loading: 'eager', fetchpriority: 'high', sizes: '100vw' }}
    {% else %}
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
    {% endif %}
  </div>

  <div class="veloute-hero-clean__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="veloute-hero-clean__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    <h1 class="veloute-hero-clean__heading">{{ section.settings.heading }}</h1>
    {% if section.settings.text != blank %}
      <p class="veloute-hero-clean__text">{{ section.settings.text }}</p>
    {% endif %}
    <div class="veloute-hero-clean__actions">
      {% if section.settings.primary_label != blank %}
        <a class="veloute-hero-clean__button veloute-hero-clean__button--primary" href="{{ primary_link }}">{{ section.settings.primary_label }}</a>
      {% endif %}
      {% if section.settings.secondary_label != blank %}
        <a class="veloute-hero-clean__button veloute-hero-clean__button--secondary" href="{{ secondary_link }}">{{ section.settings.secondary_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Veloute hero",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback image"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Desktop height",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 100
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Mobile height",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 90
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay strength",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Content vertical position",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "end", "label": "Bottom" }
      ],
      "default": "end"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Heading width",
      "min": 480,
      "max": 980,
      "step": 20,
      "unit": "px",
      "default": 760
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Veloute Boutique"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Details, die den Unterschied machen."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Schmuck und Accessoires mit ruhiger Silhouette, klarer Auswahl und hochwertigem Finish."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Damen shoppen"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Herren shoppen"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Veloute hero"
    }
  ]
}
{% endschema %}
