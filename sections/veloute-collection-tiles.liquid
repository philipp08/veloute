<section class="veloute-collection-tiles color-{{ section.settings.color_scheme }}">
  <style>
    #shopify-section-{{ section.id }} .veloute-collection-tiles {
      background: var(--color-background);
      color: var(--color-foreground);
    }

    #shopify-section-{{ section.id }} .veloute-collection-tiles__inner {
      width: min(100% - 32px, 1320px);
      margin: 0 auto;
      padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .veloute-collection-tiles__header {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 28px;
      margin-bottom: clamp(24px, 4vw, 42px);
    }

    #shopify-section-{{ section.id }} .veloute-collection-tiles__header h2 {
      margin: 0;
      max-width: 760px;
      font-family: var(--font-heading--family);
      font-size: clamp(2rem, 4.4vw, 5rem);
      line-height: .98;
      font-weight: 500;
      text-wrap: balance;
    }

    #shopify-section-{{ section.id }} .veloute-collection-tiles__header p {
      margin: 0;
      max-width: 420px;
      color: rgb(var(--color-foreground-rgb) / .66);
      line-height: 1.6;
    }

    #shopify-section-{{ section.id }} .veloute-collection-tiles__grid {
      display: grid;
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
      gap: {{ section.settings.gap }}px;
    }

    #shopify-section-{{ section.id }} .veloute-collection-tile {
      position: relative;
      min-height: {{ section.settings.tile_height }}px;
      display: grid;
      align-items: end;
      overflow: hidden;
      color: #fff;
      background: #111;
      text-decoration: none;
      isolation: isolate;
    }

    #shopify-section-{{ section.id }} .veloute-collection-tile__media,
    #shopify-section-{{ section.id }} .veloute-collection-tile__media img,
    #shopify-section-{{ section.id }} .veloute-collection-tile__media svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    #shopify-section-{{ section.id }} .veloute-collection-tile__media {
      z-index: -2;
    }

    #shopify-section-{{ section.id }} .veloute-collection-tile__media img,
    #shopify-section-{{ section.id }} .veloute-collection-tile__media svg {
      object-fit: cover;
      transition: transform .55s ease;
    }

    #shopify-section-{{ section.id }} .veloute-collection-tile::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      background: linear-gradient(0deg, rgb(0 0 0 / .68), rgb(0 0 0 / .08) 64%);
    }

    #shopify-section-{{ section.id }} .veloute-collection-tile:hover .veloute-collection-tile__media img,
    #shopify-section-{{ section.id }} .veloute-collection-tile:hover .veloute-collection-tile__media svg {
      transform: scale(1.035);
    }

    #shopify-section-{{ section.id }} .veloute-collection-tile__content {
      padding: clamp(20px, 3vw, 36px);
    }

    #shopify-section-{{ section.id }} .veloute-collection-tile__content h3 {
      margin: 0 0 10px;
      font-family: var(--font-heading--family);
      font-size: clamp(2rem, 3.6vw, 4.2rem);
      line-height: .98;
      font-weight: 500;
    }

    #shopify-section-{{ section.id }} .veloute-collection-tile__content p {
      margin: 0 0 20px;
      max-width: 430px;
      color: rgb(255 255 255 / .78);
      line-height: 1.55;
    }

    #shopify-section-{{ section.id }} .veloute-collection-tile__link {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: .78rem;
      letter-spacing: .1em;
      line-height: 1.2;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .veloute-collection-tile__link::after {
      content: "";
      width: 34px;
      height: 1px;
      background: currentColor;
      transition: width .22s ease;
    }

    #shopify-section-{{ section.id }} .veloute-collection-tile:hover .veloute-collection-tile__link::after {
      width: 50px;
    }

    @media screen and (max-width: 989px) {
      #shopify-section-{{ section.id }} .veloute-collection-tiles__grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .veloute-collection-tiles__inner {
        width: min(100% - 28px, 1320px);
      }

      #shopify-section-{{ section.id }} .veloute-collection-tiles__header {
        display: grid;
      }

      #shopify-section-{{ section.id }} .veloute-collection-tiles__grid {
        grid-template-columns: 1fr;
      }

      #shopify-section-{{ section.id }} .veloute-collection-tile {
        min-height: {{ section.settings.tile_height_mobile }}px;
      }
    }
  </style>

  <div class="veloute-collection-tiles__inner">
    {% if section.settings.heading != blank or section.settings.text != blank %}
      <div class="veloute-collection-tiles__header">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <p>{{ section.settings.text }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="veloute-collection-tiles__grid">
      {% for block in section.blocks %}
        {% liquid
          assign collection = block.settings.collection
          assign link = block.settings.link
          if link == blank and collection != blank
            assign link = collection.url
          endif
          if link == blank
            assign link = routes.all_products_collection_url
          endif

          assign image = block.settings.image
          if image == blank and collection.featured_image != blank
            assign image = collection.featured_image
          endif
          if image == blank and collection.products.first.featured_image != blank
            assign image = collection.products.first.featured_image
          endif

          assign title = block.settings.title
          if title == blank and collection != blank
            assign title = collection.title
          endif
        %}
        <a class="veloute-collection-tile" href="{{ link }}" {{ block.shopify_attributes }}>
          <div class="veloute-collection-tile__media" aria-hidden="true">
            {% if image != blank %}
              {{ image | image_url: width: 1600 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 50vw, 100vw', alt: title }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag }}
            {% endif %}
          </div>
          <div class="veloute-collection-tile__content">
            {% if title != blank %}
              <h3>{{ title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <p>{{ block.settings.text }}</p>
            {% endif %}
            {% if block.settings.label != blank %}
              <span class="veloute-collection-tile__link">{{ block.settings.label }}</span>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Veloute collection tiles",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop nach Stil."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Klare Einstiege für Damen, Herren und die wichtigsten Accessoire-Kategorien."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "tile_height",
      "label": "Tile height desktop",
      "min": 360,
      "max": 760,
      "step": 20,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "tile_height_mobile",
      "label": "Tile height mobile",
      "min": 300,
      "max": 620,
      "step": 20,
      "unit": "px",
      "default": 420
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 0,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Link label",
          "default": "Jetzt entdecken"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Veloute collection tiles",
      "blocks": [
        { "type": "tile" },
        { "type": "tile" }
      ]
    }
  ]
}
{% endschema %}
