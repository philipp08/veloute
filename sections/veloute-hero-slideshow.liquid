{{ 'veloute-reveal.css' | asset_url | stylesheet_tag }}
<script src="{{ 'veloute-reveal.js' | asset_url }}" defer></script>

{%- liquid
  assign layout = section.settings.layout_style
  assign ratio_desktop = section.settings.image_ratio_desktop
  assign ratio_mobile = section.settings.image_ratio_mobile
  assign max_height_desktop = section.settings.max_height_desktop
  assign max_height_mobile = section.settings.max_height_mobile
  assign overlay = section.settings.overlay_opacity | divided_by: 100.0
-%}

<section
  class="veloute-hero-slideshow veloute-hero-slideshow--{{ layout }} color-{{ section.settings.color_scheme }}"
  data-veloute-slideshow
  data-autoplay="{{ section.settings.autoplay }}"
  data-interval="{{ section.settings.interval | times: 1000 }}"
  aria-roledescription="carousel"
  aria-label="{% if section.settings.aria_label != blank %}{{ section.settings.aria_label | escape }}{% else %}{{ 'veloute.slideshow.region_label' | t | escape }}{% endif %}"
  style="--vh-pad-top: {{ section.settings.padding_top }}px; --vh-pad-bottom: {{ section.settings.padding_bottom }}px;"
>
  <style>
    #shopify-section-{{ section.id }} .veloute-hero-slideshow {
      --vh-ratio-desktop: {{ ratio_desktop }};
      --vh-ratio-mobile: {{ ratio_mobile }};
      --vh-max-h-desktop: {{ max_height_desktop }}px;
      --vh-max-h-mobile: {{ max_height_mobile }}px;
      --vh-overlay: {{ overlay }};
      position: relative;
      padding: var(--vh-pad-top, 32px) 0 var(--vh-pad-bottom, 32px);
      background: var(--color-background, #faf8f5);
      overflow: hidden;
      isolation: isolate;
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__container {
      width: min(100% - 32px, 1360px);
      margin: 0 auto;
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__track {
      position: relative;
    }

    /* SIDE-BY-SIDE LAYOUT */
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--side-by-side .veloute-hero-slideshow__slide {
      position: absolute;
      inset: 0;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
      gap: clamp(24px, 4vw, 64px);
      align-items: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity .9s cubic-bezier(.4,0,.2,1);
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--side-by-side .veloute-hero-slideshow__slide:first-child {
      position: relative;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--side-by-side .veloute-hero-slideshow__slide.is-active {
      opacity: 1;
      pointer-events: auto;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--side-by-side .veloute-hero-slideshow__slide[data-image-position="left"] {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--side-by-side .veloute-hero-slideshow__slide[data-image-position="left"] .veloute-hero-slideshow__media-wrap {
      order: 0;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--side-by-side .veloute-hero-slideshow__slide[data-image-position="left"] .veloute-hero-slideshow__inner {
      order: 1;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--side-by-side .veloute-hero-slideshow__media-wrap {
      order: 1;
      position: relative;
      width: 100%;
      aspect-ratio: var(--vh-ratio-desktop);
      max-height: var(--vh-max-h-desktop);
      overflow: hidden;
      background: #efece6;
      border-radius: 2px;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--side-by-side .veloute-hero-slideshow__inner {
      order: 0;
      padding: clamp(8px, 2vw, 32px) clamp(4px, 1.5vw, 16px);
    }

    /* OVERLAY LAYOUT */
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--overlay .veloute-hero-slideshow__slide {
      position: absolute;
      inset: 0;
      opacity: 0;
      pointer-events: none;
      transition: opacity .9s cubic-bezier(.4,0,.2,1);
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--overlay .veloute-hero-slideshow__slide:first-child {
      position: relative;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--overlay .veloute-hero-slideshow__slide.is-active {
      opacity: 1;
      pointer-events: auto;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--overlay .veloute-hero-slideshow__media-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: var(--vh-ratio-desktop);
      max-height: var(--vh-max-h-desktop);
      overflow: hidden;
      background: #efece6;
      border-radius: 2px;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--overlay .veloute-hero-slideshow__inner {
      position: absolute;
      left: clamp(20px, 5vw, 64px);
      right: clamp(20px, 5vw, 64px);
      bottom: clamp(24px, 5vw, 56px);
      color: #fff;
      max-width: 640px;
      z-index: 2;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--overlay .veloute-hero-slideshow__media-wrap::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgb(0 0 0 / 0) 35%, rgb(0 0 0 / calc(var(--vh-overlay) + .25)) 100%);
      pointer-events: none;
    }

    /* SHARED MEDIA */
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__media,
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__media svg,
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__media img,
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__media video {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__media img,
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__media video {
      transform: scale(1.04);
      transition: transform 1.2s cubic-bezier(.2,.7,.2,1);
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide.is-active .veloute-hero-slideshow__media img,
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide.is-active .veloute-hero-slideshow__media video {
      animation: vh-kenburns 9s ease-out forwards;
    }
    @keyframes vh-kenburns {
      from { transform: scale(1.02); }
      to   { transform: scale(1.10) translate3d(-1%, -1.2%, 0); }
    }

    /* TEXT BLOCK */
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__eyebrow,
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__heading,
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__text,
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__actions {
      opacity: 0;
      transform: translate3d(0, 14px, 0);
      transition: opacity .8s cubic-bezier(.2,.7,.2,1), transform .8s cubic-bezier(.2,.7,.2,1);
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide.is-active .veloute-hero-slideshow__eyebrow { opacity: 1; transform: none; transition-delay: .12s; }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide.is-active .veloute-hero-slideshow__heading { opacity: 1; transform: none; transition-delay: .22s; }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide.is-active .veloute-hero-slideshow__text { opacity: 1; transform: none; transition-delay: .34s; }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide.is-active .veloute-hero-slideshow__actions { opacity: 1; transform: none; transition-delay: .46s; }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__eyebrow {
      margin: 0 0 18px;
      font-size: .72rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--color-foreground, #1d1d1b);
      opacity: .7;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--overlay .veloute-hero-slideshow__eyebrow {
      color: rgb(255 255 255 / .82);
      opacity: 1;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__heading {
      margin: 0;
      font-family: var(--font-heading--family);
      font-size: clamp(2.4rem, 4.6vw, 4.8rem);
      line-height: .98;
      font-weight: 500;
      letter-spacing: -0.01em;
      color: var(--color-foreground, #1d1d1b);
      text-wrap: balance;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--overlay .veloute-hero-slideshow__heading {
      color: #fff;
      font-size: clamp(2rem, 3.6vw, 3.6rem);
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__text {
      margin: 20px 0 0;
      max-width: 480px;
      color: var(--color-foreground, #1d1d1b);
      opacity: .78;
      font-size: clamp(1rem, 1.05vw, 1.08rem);
      line-height: 1.62;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--overlay .veloute-hero-slideshow__text {
      color: rgb(255 255 255 / .85);
      opacity: 1;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 30px;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__button {
      min-height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 13px 26px;
      border: 1px solid currentColor;
      font-size: .74rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      text-decoration: none;
      transition: background-color .25s ease, color .25s ease, border-color .25s ease;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__button--primary {
      color: var(--color-background, #fff);
      background: var(--color-foreground, #1d1d1b);
      border-color: var(--color-foreground, #1d1d1b);
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__button--primary:hover {
      background: transparent;
      color: var(--color-foreground, #1d1d1b);
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__button--secondary {
      color: var(--color-foreground, #1d1d1b);
      background: transparent;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__button--secondary:hover {
      background: var(--color-foreground, #1d1d1b);
      color: var(--color-background, #fff);
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--overlay .veloute-hero-slideshow__button--primary {
      color: #111; background: #fff; border-color: #fff;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--overlay .veloute-hero-slideshow__button--primary:hover {
      background: transparent; color: #fff;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--overlay .veloute-hero-slideshow__button--secondary {
      color: #fff; border-color: rgb(255 255 255 / .55);
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow--overlay .veloute-hero-slideshow__button--secondary:hover {
      background: #fff; color: #111; border-color: #fff;
    }

    /* CONTROLS */
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__controls {
      margin-top: clamp(20px, 3vw, 32px);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__dots {
      display: flex;
      gap: 14px;
      flex: 1;
      max-width: 280px;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__dot {
      position: relative;
      flex: 1;
      height: 2px;
      background: transparent;
      border: 0;
      padding: 12px 0;
      cursor: pointer;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__dot::before {
      content: "";
      position: absolute;
      left: 0; right: 0; top: 50%;
      height: 1px;
      background: rgb(0 0 0 / .18);
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__dot::after {
      content: "";
      position: absolute;
      left: 0; top: 50%;
      height: 1px;
      width: 0%;
      background: var(--color-foreground, #1d1d1b);
      transition: width .25s linear;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__dot.is-active::after {
      width: 100%;
      transition: width var(--vh-progress-duration, 6s) linear;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__counter {
      font-size: .72rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--color-foreground, #1d1d1b);
      opacity: .65;
      font-variant-numeric: tabular-nums;
    }

    /* MOBILE */
    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .veloute-hero-slideshow--side-by-side .veloute-hero-slideshow__slide {
        grid-template-columns: 1fr !important;
        gap: 24px;
      }
      #shopify-section-{{ section.id }} .veloute-hero-slideshow--side-by-side .veloute-hero-slideshow__media-wrap,
      #shopify-section-{{ section.id }} .veloute-hero-slideshow--side-by-side .veloute-hero-slideshow__slide[data-image-position="left"] .veloute-hero-slideshow__media-wrap {
        order: 0 !important;
        aspect-ratio: var(--vh-ratio-mobile);
        max-height: var(--vh-max-h-mobile);
      }
      #shopify-section-{{ section.id }} .veloute-hero-slideshow--side-by-side .veloute-hero-slideshow__inner,
      #shopify-section-{{ section.id }} .veloute-hero-slideshow--side-by-side .veloute-hero-slideshow__slide[data-image-position="left"] .veloute-hero-slideshow__inner {
        order: 1 !important;
        padding: 4px 4px 8px;
      }
      #shopify-section-{{ section.id }} .veloute-hero-slideshow--overlay .veloute-hero-slideshow__media-wrap {
        aspect-ratio: var(--vh-ratio-mobile);
        max-height: var(--vh-max-h-mobile);
      }
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__heading {
        font-size: clamp(2rem, 8vw, 2.8rem);
      }
      #shopify-section-{{ section.id }} .veloute-hero-slideshow--overlay .veloute-hero-slideshow__heading {
        font-size: clamp(1.6rem, 6.5vw, 2.4rem);
      }
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__button { flex: 1; }
    }

    @media (prefers-reduced-motion: reduce) {
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide,
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__eyebrow,
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__heading,
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__text,
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__actions {
        transition: none !important;
      }
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__media img,
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__media video {
        animation: none !important;
        transform: none !important;
      }
    }
  </style>

  <div class="veloute-hero-slideshow__container">
    <div class="veloute-hero-slideshow__track">
      {% for block in section.blocks %}
        {% liquid
          assign primary_link = block.settings.primary_link
          if primary_link == blank
            assign primary_link = routes.all_products_collection_url
          endif
          assign secondary_link = block.settings.secondary_link
          if secondary_link == blank
            assign secondary_link = routes.all_products_collection_url
          endif
          if forloop.first
            assign img_loading = 'eager'
            assign img_priority = 'high'
          else
            assign img_loading = 'lazy'
            assign img_priority = 'low'
          endif
          assign img_position = block.settings.image_position | default: 'right'
        %}
        <div
          class="veloute-hero-slideshow__slide{% if forloop.first %} is-active{% endif %}"
          data-slide-index="{{ forloop.index0 }}"
          data-image-position="{{ img_position }}"
          role="group"
          aria-roledescription="slide"
          aria-label="{{ 'veloute.slideshow.slide_of' | t: current: forloop.index, total: section.blocks.size }}"
          {{ block.shopify_attributes }}
        >
          <div class="veloute-hero-slideshow__media-wrap">
            <div class="veloute-hero-slideshow__media" aria-hidden="true">
              {% if block.settings.video != blank %}
                {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
              {% elsif block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 1800 | image_tag:
                    loading: img_loading,
                    fetchpriority: img_priority,
                    sizes: '(min-width: 750px) 60vw, 100vw',
                    widths: '600,900,1200,1500,1800',
                    alt: block.settings.heading }}
              {% else %}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'veloute-hero-slideshow__placeholder' }}
              {% endif %}
            </div>
          </div>

          <div class="veloute-hero-slideshow__inner">
            {% if block.settings.eyebrow != blank %}
              <p class="veloute-hero-slideshow__eyebrow">{{ block.settings.eyebrow }}</p>
            {% endif %}
            <h2 class="veloute-hero-slideshow__heading">{{ block.settings.heading }}</h2>
            {% if block.settings.text != blank %}
              <p class="veloute-hero-slideshow__text">{{ block.settings.text }}</p>
            {% endif %}
            {% if block.settings.primary_label != blank or block.settings.secondary_label != blank %}
              <div class="veloute-hero-slideshow__actions">
                {% if block.settings.primary_label != blank %}
                  <a class="veloute-hero-slideshow__button veloute-hero-slideshow__button--primary" href="{{ primary_link }}">{{ block.settings.primary_label }}</a>
                {% endif %}
                {% if block.settings.secondary_label != blank %}
                  <a class="veloute-hero-slideshow__button veloute-hero-slideshow__button--secondary" href="{{ secondary_link }}">{{ block.settings.secondary_label }}</a>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.blocks.size > 1 %}
      <div class="veloute-hero-slideshow__controls">
        <div class="veloute-hero-slideshow__dots" role="tablist" aria-label="{{ 'veloute.slideshow.dots_label' | t }}">
          {% for block in section.blocks %}
            <button
              type="button"
              class="veloute-hero-slideshow__dot{% if forloop.first %} is-active{% endif %}"
              data-slide-to="{{ forloop.index0 }}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-label="{{ 'veloute.slideshow.go_to_slide' | t: index: forloop.index }}"
              style="--vh-progress-duration: {{ section.settings.interval }}s;"
            ></button>
          {% endfor %}
        </div>
        <div class="veloute-hero-slideshow__counter" aria-live="polite">
          <span data-slide-current>01</span> / <span data-slide-total>{{ section.blocks.size | prepend: '0' | slice: -2, 2 }}</span>
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script>
(function () {
  document.querySelectorAll('[data-veloute-slideshow]').forEach(function (section) {
    if (section.dataset.vhBound === '1') return;
    section.dataset.vhBound = '1';

    var slides = Array.prototype.slice.call(section.querySelectorAll('.veloute-hero-slideshow__slide'));
    var dots = Array.prototype.slice.call(section.querySelectorAll('.veloute-hero-slideshow__dot'));
    var counterCurrent = section.querySelector('[data-slide-current]');
    if (slides.length <= 1) return;

    var index = 0;
    var interval = parseInt(section.dataset.interval, 10) || 6000;
    var autoplay = section.dataset.autoplay === 'true';
    var timer = null;
    var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function pad(n) { return n < 10 ? '0' + n : '' + n; }

    function go(i) {
      index = (i + slides.length) % slides.length;
      slides.forEach(function (s, idx) {
        s.classList.toggle('is-active', idx === index);
      });
      dots.forEach(function (d, idx) {
        d.classList.remove('is-active');
        d.setAttribute('aria-selected', idx === index ? 'true' : 'false');
        if (idx === index) {
          void d.offsetWidth;
          d.classList.add('is-active');
        }
      });
      if (counterCurrent) counterCurrent.textContent = pad(index + 1);
    }

    function next() { go(index + 1); }

    function start() {
      if (!autoplay || reduced) return;
      stop();
      timer = window.setInterval(next, interval);
    }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        var i = parseInt(dot.getAttribute('data-slide-to'), 10) || 0;
        go(i);
        start();
      });
    });

    section.addEventListener('mouseenter', stop);
    section.addEventListener('mouseleave', start);
    section.addEventListener('focusin', stop);
    section.addEventListener('focusout', start);

    section.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowRight') { next(); start(); }
      else if (e.key === 'ArrowLeft') { go(index - 1); start(); }
    });

    document.addEventListener('visibilitychange', function () {
      if (document.hidden) stop(); else start();
    });

    go(0);
    start();
  });
})();
</script>

{% schema %}
{
  "name": "Veloute Hero-Slideshow",
  "tag": "section",
  "class": "section-veloute-hero-slideshow",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Desktop-Layout",
      "options": [
        { "value": "side-by-side", "label": "Editorial – Bild & Text nebeneinander" },
        { "value": "overlay", "label": "Banner mit Textoverlay" }
      ],
      "default": "side-by-side"
    },
    {
      "type": "select",
      "id": "image_ratio_desktop",
      "label": "Bildverhältnis Desktop",
      "options": [
        { "value": "16 / 9", "label": "16:9 (breit)" },
        { "value": "3 / 2", "label": "3:2" },
        { "value": "4 / 3", "label": "4:3" },
        { "value": "1 / 1", "label": "1:1 (quadratisch)" }
      ],
      "default": "4 / 3"
    },
    {
      "type": "select",
      "id": "image_ratio_mobile",
      "label": "Bildverhältnis Mobil",
      "options": [
        { "value": "4 / 5", "label": "4:5 (portrait)" },
        { "value": "1 / 1", "label": "1:1" },
        { "value": "3 / 4", "label": "3:4" },
        { "value": "16 / 9", "label": "16:9" }
      ],
      "default": "4 / 5"
    },
    {
      "type": "range",
