{{ 'veloute-reveal.css' | asset_url | stylesheet_tag }}
<script src="{{ 'veloute-reveal.js' | asset_url }}" defer></script>

<section
  class="veloute-hero-slideshow color-{{ section.settings.color_scheme }}"
  data-veloute-slideshow
  data-autoplay="{{ section.settings.autoplay }}"
  data-interval="{{ section.settings.interval | times: 1000 }}"
  aria-roledescription="carousel"
  aria-label="{{ section.settings.aria_label | default: 'Veloute Slideshow' | escape }}"
>
  <style>
    #shopify-section-{{ section.id }} .veloute-hero-slideshow {
      --hero-height-desktop: {{ section.settings.height_desktop }}svh;
      --hero-height-mobile: {{ section.settings.height_mobile }}svh;
      --hero-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
      position: relative;
      min-height: var(--hero-height-desktop);
      overflow: hidden;
      color: #fff;
      background: #0c0c0c;
      isolation: isolate;
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__track {
      position: relative;
      min-height: var(--hero-height-desktop);
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide {
      position: absolute;
      inset: 0;
      display: grid;
      align-items: end;
      opacity: 0;
      pointer-events: none;
      transition: opacity 1.1s cubic-bezier(.4,.0,.2,1);
      isolation: isolate;
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide.is-active {
      opacity: 1;
      pointer-events: auto;
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__media {
      position: absolute;
      inset: 0;
      z-index: -2;
      overflow: hidden;
      background: #0c0c0c;
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__media img,
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__media video {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transform: scale(1.06);
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide.is-active .veloute-hero-slideshow__media img,
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide.is-active .veloute-hero-slideshow__media video {
      animation: vh-kenburns 9s ease-out forwards;
    }

    @keyframes vh-kenburns {
      from { transform: scale(1.02) translate3d(0,0,0); }
      to   { transform: scale(1.12) translate3d(-1.2%, -1.4%, 0); }
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      background:
        linear-gradient(90deg, rgb(0 0 0 / calc(var(--hero-overlay) + .12)), rgb(0 0 0 / calc(var(--hero-overlay) * .5)) 48%, rgb(0 0 0 / .1)),
        linear-gradient(0deg, rgb(0 0 0 / .55), rgb(0 0 0 / .02) 64%);
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__inner {
      width: min(100% - 32px, 1320px);
      margin: 0 auto;
      padding: clamp(96px, 12vw, 168px) 0 clamp(48px, 7vw, 100px);
      display: grid;
      justify-items: start;
      text-align: left;
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__eyebrow,
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__heading,
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__text,
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__actions {
      opacity: 0;
      transform: translate3d(0, 18px, 0);
      transition: opacity .9s cubic-bezier(.2,.7,.2,1), transform .9s cubic-bezier(.2,.7,.2,1);
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide.is-active .veloute-hero-slideshow__eyebrow { opacity: 1; transform: none; transition-delay: .15s; }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide.is-active .veloute-hero-slideshow__heading { opacity: 1; transform: none; transition-delay: .25s; }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide.is-active .veloute-hero-slideshow__text { opacity: 1; transform: none; transition-delay: .38s; }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide.is-active .veloute-hero-slideshow__actions { opacity: 1; transform: none; transition-delay: .5s; }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__eyebrow {
      margin: 0 0 22px;
      font-size: .72rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: rgb(255 255 255 / .82);
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__heading {
      margin: 0;
      width: min(100%, 920px);
      font-family: var(--font-heading--family);
      font-size: clamp(2.8rem, 7.6vw, 8rem);
      line-height: .92;
      font-weight: 500;
      letter-spacing: -0.005em;
      text-wrap: balance;
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__text {
      margin: 24px 0 0;
      width: min(100%, 560px);
      color: rgb(255 255 255 / .8);
      font-size: clamp(1rem, 1.2vw, 1.12rem);
      line-height: 1.65;
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 36px;
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__button {
      min-width: 168px;
      min-height: 50px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 26px;
      border: 1px solid currentColor;
      font-size: .76rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      text-decoration: none;
      transition: transform .3s ease, background-color .3s ease, color .3s ease, border-color .3s ease;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__button--primary {
      color: #111; background: #fff; border-color: #fff;
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__button--primary:hover { background: transparent; color: #fff; }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__button--secondary {
      color: #fff; background: transparent; border-color: rgb(255 255 255 / .55);
    }
    #shopify-section-{{ section.id }} .veloute-hero-slideshow__button--secondary:hover { background: #fff; color: #111; border-color: #fff; }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__controls {
      position: absolute;
      left: 0; right: 0; bottom: clamp(18px, 3vw, 32px);
      width: min(100% - 32px, 1320px);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      z-index: 3;
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__dots {
      display: flex;
      gap: 14px;
      flex: 1;
      max-width: 360px;
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__dot {
      position: relative;
      flex: 1;
      height: 2px;
      background: rgb(255 255 255 / .25);
      border: 0;
      padding: 14px 0;
      cursor: pointer;
      overflow: visible;
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__dot::before {
      content: "";
      position: absolute;
      left: 0; right: 0; top: 50%;
      height: 1px;
      background: rgb(255 255 255 / .3);
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__dot::after {
      content: "";
      position: absolute;
      left: 0; top: 50%;
      height: 1px;
      width: 0%;
      background: #fff;
      transition: width .25s linear;
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__dot.is-active::after {
      width: 100%;
      transition: width var(--vh-progress-duration, 6s) linear;
    }

    #shopify-section-{{ section.id }} .veloute-hero-slideshow__counter {
      font-size: .72rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: rgb(255 255 255 / .8);
      font-variant-numeric: tabular-nums;
    }

    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .veloute-hero-slideshow,
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__track {
        min-height: var(--hero-height-mobile);
      }
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__heading {
        font-size: clamp(2.4rem, 11vw, 4.2rem);
      }
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__button {
        flex: 1;
        min-width: 0;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__slide,
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__eyebrow,
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__heading,
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__text,
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__actions {
        transition: none !important;
      }
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__media img,
      #shopify-section-{{ section.id }} .veloute-hero-slideshow__media video {
        animation: none !important;
        transform: none !important;
      }
    }
  </style>

  <div class="veloute-hero-slideshow__track">
    {% for block in section.blocks %}
      {% liquid
        assign primary_link = block.settings.primary_link
        if primary_link == blank
          assign primary_link = routes.all_products_collection_url
        endif
        assign secondary_link = block.settings.secondary_link
        if secondary_link == blank
          assign secondary_link = routes.all_products_collection_url
        endif
        if forloop.first
          assign img_loading = 'eager'
          assign img_priority = 'high'
        else
          assign img_loading = 'lazy'
          assign img_priority = 'low'
        endif
      %}
      <div
        class="veloute-hero-slideshow__slide{% if forloop.first %} is-active{% endif %}"
        data-slide-index="{{ forloop.index0 }}"
        role="group"
        aria-roledescription="slide"
        aria-label="{{ forloop.index }} von {{ section.blocks.size }}"
        {{ block.shopify_attributes }}
      >
        <div class="veloute-hero-slideshow__media" aria-hidden="true">
          {% if block.settings.video != blank %}
            {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
          {% elsif block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 2800 | image_tag:
                loading: img_loading,
                fetchpriority: img_priority,
                sizes: '100vw',
                widths: '750,1100,1500,1900,2400,2800',
                alt: block.settings.heading }}
          {% else %}
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
          {% endif %}
        </div>

        <div class="veloute-hero-slideshow__inner">
          {% if block.settings.eyebrow != blank %}
            <p class="veloute-hero-slideshow__eyebrow">{{ block.settings.eyebrow }}</p>
          {% endif %}
          <h1 class="veloute-hero-slideshow__heading">{{ block.settings.heading }}</h1>
          {% if block.settings.text != blank %}
            <p class="veloute-hero-slideshow__text">{{ block.settings.text }}</p>
          {% endif %}
          {% if block.settings.primary_label != blank or block.settings.secondary_label != blank %}
            <div class="veloute-hero-slideshow__actions">
              {% if block.settings.primary_label != blank %}
                <a class="veloute-hero-slideshow__button veloute-hero-slideshow__button--primary" href="{{ primary_link }}">{{ block.settings.primary_label }}</a>
              {% endif %}
              {% if block.settings.secondary_label != blank %}
                <a class="veloute-hero-slideshow__button veloute-hero-slideshow__button--secondary" href="{{ secondary_link }}">{{ block.settings.secondary_label }}</a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  {% if section.blocks.size > 1 %}
    <div class="veloute-hero-slideshow__controls">
      <div class="veloute-hero-slideshow__dots" role="tablist" aria-label="Slides">
        {% for block in section.blocks %}
          <button
            type="button"
            class="veloute-hero-slideshow__dot{% if forloop.first %} is-active{% endif %}"
            data-slide-to="{{ forloop.index0 }}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-label="Slide {{ forloop.index }}"
            style="--vh-progress-duration: {{ section.settings.interval }}s;"
          ></button>
        {% endfor %}
      </div>
      <div class="veloute-hero-slideshow__counter" aria-live="polite">
        <span data-slide-current>01</span> / <span data-slide-total>{{ section.blocks.size | prepend: '0' | slice: -2, 2 }}</span>
      </div>
    </div>
  {% endif %}
</section>

<script>
(function () {
  var root = document.querySelector('[data-veloute-slideshow][aria-label]');
  // bind every instance
  document.querySelectorAll('[data-veloute-slideshow]').forEach(function (section) {
    if (section.dataset.vhBound === '1') return;
    section.dataset.vhBound = '1';

    var slides = Array.prototype.slice.call(section.querySelectorAll('.veloute-hero-slideshow__slide'));
    var dots = Array.prototype.slice.call(section.querySelectorAll('.veloute-hero-slideshow__dot'));
    var counterCurrent = section.querySelector('[data-slide-current]');
    if (slides.length <= 1) return;

    var index = 0;
    var interval = parseInt(section.dataset.interval, 10) || 6000;
    var autoplay = section.dataset.autoplay === 'true';
    var timer = null;
    var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function pad(n) { return n < 10 ? '0' + n : '' + n; }

    function go(i) {
      index = (i + slides.length) % slides.length;
      slides.forEach(function (s, idx) {
        s.classList.toggle('is-active', idx === index);
      });
      dots.forEach(function (d, idx) {
        d.classList.remove('is-active');
        d.setAttribute('aria-selected', idx === index ? 'true' : 'false');
        // force reflow to restart progress animation
        if (idx === index) {
          void d.offsetWidth;
          d.classList.add('is-active');
        }
      });
      if (counterCurrent) counterCurrent.textContent = pad(index + 1);
    }

    function next() { go(index + 1); }

    function start() {
      if (!autoplay || reduced) return;
      stop();
      timer = window.setInterval(next, interval);
    }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        var i = parseInt(dot.getAttribute('data-slide-to'), 10) || 0;
        go(i);
        start();
      });
    });

    section.addEventListener('mouseenter', stop);
    section.addEventListener('mouseleave', start);
    section.addEventListener('focusin', stop);
    section.addEventListener('focusout', start);

    section.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowRight') { next(); start(); }
      else if (e.key === 'ArrowLeft') { go(index - 1); start(); }
    });

    document.addEventListener('visibilitychange', function () {
      if (document.hidden) stop(); else start();
    });

    // initial progress bar
    go(0);
    start();
  });
})();
</script>

{% schema %}
{
  "name": "Veloute Hero-Slideshow",
  "tag": "section",
  "class": "section-veloute-hero-slideshow",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Desktop-Höhe",
      "min": 70, "max": 100, "step": 5, "unit": "vh", "default": 100
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Mobile-Höhe",
      "min": 60, "max": 100, "step": 5, "unit": "vh", "default": 90
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay-Stärke",
      "min": 0, "max": 80, "step": 5, "unit": "%", "default": 35
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Automatisch wechseln",
      "default": true
    },
    {
      "type": "range",
      "id": "interval",
      "label": "Slide-Dauer",
      "min": 4, "max": 12, "step": 1, "unit": "s", "default": 6
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA-Label",
      "default": "Veloute Slideshow"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "video", "id": "video", "label": "Video (überschreibt Bild)" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Neue Kollektion" },
        { "type": "text", "id": "heading", "label": "Überschrift", "default": "Details, die den Unterschied machen." },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Schmuck und Accessoires mit ruhiger Silhouette, klarer Auswahl und hochwertigem Finish." },
        { "type": "text", "id": "primary_label", "label": "Primärer Button", "default": "Damen shoppen" },
        { "type": "url", "id": "primary_link", "label": "Primärer Link" },
        { "type": "text", "id": "secondary_label", "label": "Sekundärer Button", "default": "Herren shoppen" },
        { "type": "url", "id": "secondary_link", "label": "Sekundärer Link" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Veloute Hero-Slideshow",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
