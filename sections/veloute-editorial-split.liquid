{{ 'veloute-reveal.css' | asset_url | stylesheet_tag }}
<script src="{{ 'veloute-reveal.js' | asset_url }}" defer></script>

<section class="veloute-editorial-split color-{{ section.settings.color_scheme }}">
  <style>
    #shopify-section-{{ section.id }} .veloute-editorial-split {
      background: var(--color-background);
      color: var(--color-foreground);
      padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .veloute-editorial-split__inner {
      width: min(100% - 32px, 1320px);
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.05fr 1fr;
      gap: clamp(28px, 5vw, 84px);
      align-items: center;
      {% if section.settings.image_position == 'right' %}
      direction: rtl;
      {% endif %}
    }

    #shopify-section-{{ section.id }} .veloute-editorial-split__inner > * { direction: ltr; }

    #shopify-section-{{ section.id }} .veloute-editorial-split__media {
      position: relative;
      aspect-ratio: 4 / 5;
      overflow: hidden;
      background: #111;
    }

    #shopify-section-{{ section.id }} .veloute-editorial-split__media img,
    #shopify-section-{{ section.id }} .veloute-editorial-split__media svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 1.2s cubic-bezier(.2,.7,.2,1);
    }

    #shopify-section-{{ section.id }} .veloute-editorial-split:hover .veloute-editorial-split__media img {
      transform: scale(1.04);
    }

    #shopify-section-{{ section.id }} .veloute-editorial-split__content {
      max-width: 540px;
    }

    #shopify-section-{{ section.id }} .veloute-editorial-split__eyebrow {
      margin: 0 0 22px;
      font-size: .72rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: rgb(var(--color-foreground-rgb) / .6);
    }

    #shopify-section-{{ section.id }} .veloute-editorial-split__heading {
      margin: 0;
      font-family: var(--font-heading--family);
      font-size: clamp(2.4rem, 5vw, 5.4rem);
      line-height: .96;
      font-weight: 500;
      letter-spacing: -.005em;
      text-wrap: balance;
    }

    #shopify-section-{{ section.id }} .veloute-editorial-split__text {
      margin: 26px 0 0;
      color: rgb(var(--color-foreground-rgb) / .72);
      font-size: 1.05rem;
      line-height: 1.7;
    }

    #shopify-section-{{ section.id }} .veloute-editorial-split__button {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      margin-top: 34px;
      padding: 0 0 6px;
      border: 0;
      background: none;
      color: inherit;
      font-size: .76rem;
      letter-spacing: .16em;
      text-transform: uppercase;
      text-decoration: none;
      border-bottom: 1px solid currentColor;
    }
    #shopify-section-{{ section.id }} .veloute-editorial-split__button::after {
      content: "→";
      transition: transform .35s ease;
    }
    #shopify-section-{{ section.id }} .veloute-editorial-split__button:hover::after {
      transform: translateX(6px);
    }

    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .veloute-editorial-split__inner {
        grid-template-columns: 1fr;
        direction: ltr;
        gap: 32px;
      }
    }
  </style>

  <div class="veloute-editorial-split__inner">
    <div class="veloute-editorial-split__media" data-reveal>
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1600 | image_tag:
            loading: 'lazy',
            sizes: '(min-width: 990px) 50vw, 100vw',
            widths: '600,900,1200,1600',
            alt: section.settings.heading }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag }}
      {% endif %}
    </div>
    <div class="veloute-editorial-split__content">
      {% if section.settings.eyebrow != blank %}
        <p class="veloute-editorial-split__eyebrow" data-reveal>{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="veloute-editorial-split__heading" data-reveal data-reveal-delay="1">{{ section.settings.heading }}</h2>
      {% if section.settings.text != blank %}
        <p class="veloute-editorial-split__text" data-reveal data-reveal-delay="2">{{ section.settings.text }}</p>
      {% endif %}
      {% if section.settings.button_label != blank %}
        <a class="veloute-editorial-split__button" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" data-reveal data-reveal-delay="3">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Veloute Editorial Split",
  "tag": "section",
  "class": "section-veloute-editorial-split",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "image_picker", "id": "image", "label": "Bild" },
    {
      "type": "select",
      "id": "image_position",
      "label": "Bild Position",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Unser Stil" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Ruhige Stücke. Tragbar jeden Tag." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Wir kuratieren Schmuck und Accessoires, die nicht laut sein müssen. Klare Linien, feine Materialien, präzise verarbeitet – damit jedes Detail seinen Platz hat." },
    { "type": "text", "id": "button_label", "label": "Button-Text", "default": "Mehr über Veloute" },
    { "type": "url", "id": "button_link", "label": "Button-Link" },
    { "type": "range", "id": "padding_top", "label": "Padding oben", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_bottom", "label": "Padding unten", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 120 }
  ],
  "presets": [
    { "name": "Veloute Editorial Split" }
  ]
}
{% endschema %}
