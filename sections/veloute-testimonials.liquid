{{ 'veloute-reveal.css' | asset_url | stylesheet_tag }}
<script src="{{ 'veloute-reveal.js' | asset_url }}" defer></script>

<section class="veloute-testimonials color-{{ section.settings.color_scheme }}">
  <style>
    #shopify-section-{{ section.id }} .veloute-testimonials {
      background: var(--color-background);
      color: var(--color-foreground);
      padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
      border-top: 1px solid rgb(var(--color-foreground-rgb) / .08);
    }

    #shopify-section-{{ section.id }} .veloute-testimonials__inner {
      width: min(100% - 32px, 1320px);
      margin: 0 auto;
    }

    #shopify-section-{{ section.id }} .veloute-testimonials__header {
      text-align: center;
      margin-bottom: clamp(40px, 6vw, 80px);
    }

    #shopify-section-{{ section.id }} .veloute-testimonials__eyebrow {
      margin: 0 0 14px;
      font-size: .72rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: rgb(var(--color-foreground-rgb) / .6);
    }

    #shopify-section-{{ section.id }} .veloute-testimonials__heading {
      margin: 0;
      font-family: var(--font-heading--family);
      font-size: clamp(2rem, 4vw, 4rem);
      line-height: 1;
      font-weight: 500;
      letter-spacing: -.005em;
    }

    #shopify-section-{{ section.id }} .veloute-testimonials__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(28px, 4vw, 56px);
    }

    #shopify-section-{{ section.id }} .veloute-testimonial {
      position: relative;
      padding: clamp(28px, 3vw, 44px) 0 0;
    }

    #shopify-section-{{ section.id }} .veloute-testimonial::before {
      content: "\201C";
      position: absolute;
      top: -28px;
      left: -8px;
      font-family: var(--font-heading--family);
      font-size: 7rem;
      line-height: 1;
      color: rgb(var(--color-foreground-rgb) / .14);
    }

    #shopify-section-{{ section.id }} .veloute-testimonial__quote {
      margin: 0 0 28px;
      font-family: var(--font-heading--family);
      font-size: clamp(1.2rem, 1.6vw, 1.55rem);
      line-height: 1.4;
      font-weight: 400;
      letter-spacing: -.002em;
    }

    #shopify-section-{{ section.id }} .veloute-testimonial__author {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: .82rem;
      line-height: 1.4;
    }

    #shopify-section-{{ section.id }} .veloute-testimonial__avatar {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      object-fit: cover;
      background: rgb(var(--color-foreground-rgb) / .08);
    }

    #shopify-section-{{ section.id }} .veloute-testimonial__name {
      font-weight: 500;
    }

    #shopify-section-{{ section.id }} .veloute-testimonial__role {
      color: rgb(var(--color-foreground-rgb) / .6);
      font-size: .76rem;
    }

    @media screen and (max-width: 989px) {
      #shopify-section-{{ section.id }} .veloute-testimonials__grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="veloute-testimonials__inner">
    {% if section.settings.heading != blank or section.settings.eyebrow != blank %}
      <div class="veloute-testimonials__header">
        {% if section.settings.eyebrow != blank %}
          <p class="veloute-testimonials__eyebrow" data-reveal>{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="veloute-testimonials__heading" data-reveal data-reveal-delay="1">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
    {% endif %}

    <div class="veloute-testimonials__grid">
      {% for block in section.blocks %}
        <figure class="veloute-testimonial" data-reveal data-reveal-delay="{{ forloop.index }}" {{ block.shopify_attributes }}>
          <blockquote class="veloute-testimonial__quote">{{ block.settings.quote }}</blockquote>
          <figcaption class="veloute-testimonial__author">
            {% if block.settings.avatar != blank %}
              {{ block.settings.avatar | image_url: width: 120 | image_tag: loading: 'lazy', class: 'veloute-testimonial__avatar', alt: block.settings.name }}
            {% endif %}
            <span>
              {% if block.settings.name != blank %}
                <span class="veloute-testimonial__name">{{ block.settings.name }}</span><br>
              {% endif %}
              {% if block.settings.role != blank %}
                <span class="veloute-testimonial__role">{{ block.settings.role }}</span>
              {% endif %}
            </span>
          </figcaption>
        </figure>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Veloute Testimonials",
  "tag": "section",
  "class": "section-veloute-testimonials",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stimmen" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Was unsere Kundinnen sagen." },
    { "type": "range", "id": "padding_top", "label": "Padding oben", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Padding unten", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 100 }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Zitat",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Zitat", "default": "Genau die ruhigen Stücke, die ich gesucht habe. Trage sie jeden Tag." },
        { "type": "text", "id": "name", "label": "Name", "default": "Lena" },
        { "type": "text", "id": "role", "label": "Rolle / Ort", "default": "Berlin" },
        { "type": "image_picker", "id": "avatar", "label": "Avatar" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Veloute Testimonials",
      "blocks": [
        { "type": "quote", "settings": { "quote": "Endlich Schmuck, der zum Look passt – nicht andersrum. Verarbeitung top.", "name": "Lena", "role": "Berlin" } },
        { "type": "quote", "settings": { "quote": "Geschenkverpackung sieht aus wie aus einer Boutique. Wurde direkt verschenkt.", "name": "Sophia", "role": "München" } },
        { "type": "quote", "settings": { "quote": "Klare Auswahl, schneller Versand, faire Preise. Bin Stammkundin.", "name": "Mira", "role": "Hamburg" } }
      ]
    }
  ]
}
{% endschema %}
