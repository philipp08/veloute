{% liquid
  assign hero_collection = section.settings.highlights_collection
  assign fallback_product = hero_collection.products.first
  if fallback_product == blank
    assign fallback_product = collections.all.products.first
  endif

  assign womens_collection = section.settings.womens_collection
  assign mens_collection = section.settings.mens_collection
  assign highlights_collection = section.settings.highlights_collection
  assign necklace_collection = section.settings.necklace_collection
  assign bracelet_collection = section.settings.bracelet_collection
  assign keychain_collection = section.settings.keychain_collection
%}

<section class="veloute-home color-{{ section.settings.color_scheme }}">
  <style>
    #shopify-section-{{ section.id }} .veloute-home {
      --veloute-ink: rgb(var(--color-foreground-rgb));
      --veloute-muted: rgb(var(--color-foreground-rgb) / .68);
      --veloute-line: rgb(var(--color-foreground-rgb) / .14);
      --veloute-panel: rgb(var(--color-foreground-rgb) / .045);
      --veloute-dark: #0d0c0b;
      color: var(--veloute-ink);
      background: rgb(var(--color-background-rgb));
      overflow: clip;
    }

    #shopify-section-{{ section.id }} .veloute-hero {
      position: relative;
      min-height: min(860px, 94svh);
      display: grid;
      align-items: end;
      isolation: isolate;
      background: #111;
      color: #fff;
    }

    #shopify-section-{{ section.id }} .veloute-hero__media,
    #shopify-section-{{ section.id }} .veloute-hero__media video,
    #shopify-section-{{ section.id }} .veloute-hero__media img,
    #shopify-section-{{ section.id }} .veloute-hero__placeholder {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    #shopify-section-{{ section.id }} .veloute-hero__media video,
    #shopify-section-{{ section.id }} .veloute-hero__media img {
      object-fit: cover;
    }

    #shopify-section-{{ section.id }} .veloute-hero__placeholder {
      background:
        linear-gradient(140deg, rgba(255,255,255,.12), rgba(255,255,255,0) 42%),
        radial-gradient(circle at 80% 20%, rgba(255,255,255,.18), transparent 28%),
        #171411;
    }

    #shopify-section-{{ section.id }} .veloute-hero::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      background:
        linear-gradient(90deg, rgba(0,0,0,.72), rgba(0,0,0,.28) 48%, rgba(0,0,0,.08)),
        linear-gradient(0deg, rgba(0,0,0,.72), rgba(0,0,0,0) 48%);
    }

    #shopify-section-{{ section.id }} .veloute-hero__inner {
      width: min(100% - 32px, 1220px);
      margin: 0 auto;
      padding: clamp(96px, 13vw, 168px) 0 clamp(34px, 5vw, 72px);
      display: grid;
      grid-template-columns: minmax(0, 740px) minmax(250px, 360px);
      gap: clamp(28px, 6vw, 92px);
      align-items: end;
    }

    #shopify-section-{{ section.id }} .veloute-kicker {
      margin: 0 0 18px;
      font-size: .76rem;
      line-height: 1.35;
      letter-spacing: .14em;
      text-transform: uppercase;
      opacity: .9;
    }

    #shopify-section-{{ section.id }} .veloute-hero h1 {
      margin: 0;
      max-width: 760px;
      font-family: var(--font-heading--family);
      font-size: clamp(3.15rem, 8vw, 7.4rem);
      line-height: .9;
      font-weight: 500;
      text-wrap: balance;
    }

    #shopify-section-{{ section.id }} .veloute-hero__copy {
      margin: 22px 0 0;
      max-width: 560px;
      color: rgba(255,255,255,.82);
      font-size: clamp(1rem, 1.4vw, 1.16rem);
      line-height: 1.65;
    }

    #shopify-section-{{ section.id }} .veloute-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 32px;
    }

    #shopify-section-{{ section.id }} .veloute-button {
      min-height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 22px;
      border: 1px solid currentColor;
      border-radius: 0;
      font-size: .78rem;
      letter-spacing: .1em;
      line-height: 1.2;
      text-transform: uppercase;
      text-decoration: none;
      transition: transform .24s ease, background-color .24s ease, color .24s ease, border-color .24s ease;
    }

    #shopify-section-{{ section.id }} .veloute-button:hover {
      transform: translateY(-2px);
    }

    #shopify-section-{{ section.id }} .veloute-button--light {
      background: #fff;
      color: #111;
      border-color: #fff;
    }

    #shopify-section-{{ section.id }} .veloute-button--ghost {
      color: #fff;
      background: rgba(255,255,255,.08);
      border-color: rgba(255,255,255,.42);
      backdrop-filter: blur(8px);
    }

    #shopify-section-{{ section.id }} .veloute-hero__aside {
      border-top: 1px solid rgba(255,255,255,.36);
      padding-top: 20px;
      color: rgba(255,255,255,.82);
      display: grid;
      gap: 18px;
    }

    #shopify-section-{{ section.id }} .veloute-hero__aside strong {
      display: block;
      color: #fff;
      font-size: .8rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      margin-bottom: 4px;
    }

    #shopify-section-{{ section.id }} .veloute-band {
      width: min(100% - 32px, 1220px);
      margin: 0 auto;
      padding: clamp(54px, 7vw, 96px) 0;
    }

    #shopify-section-{{ section.id }} .veloute-proof {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      border-bottom: 1px solid var(--veloute-line);
      padding: 20px 0;
      gap: 18px;
    }

    #shopify-section-{{ section.id }} .veloute-proof__item {
      display: grid;
      gap: 5px;
    }

    #shopify-section-{{ section.id }} .veloute-proof__item span {
      font-size: .72rem;
      letter-spacing: .12em;
      line-height: 1.25;
      text-transform: uppercase;
      color: var(--veloute-muted);
    }

    #shopify-section-{{ section.id }} .veloute-proof__item strong {
      font-size: .98rem;
      font-weight: 500;
    }

    #shopify-section-{{ section.id }} .veloute-section-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 24px;
      margin-bottom: clamp(24px, 4vw, 42px);
    }

    #shopify-section-{{ section.id }} .veloute-section-head h2 {
      margin: 0;
      max-width: 720px;
      font-family: var(--font-heading--family);
      font-size: clamp(2.1rem, 4.6vw, 5rem);
      line-height: .96;
      font-weight: 500;
      text-wrap: balance;
    }

    #shopify-section-{{ section.id }} .veloute-section-head p {
      margin: 0;
      max-width: 390px;
      color: var(--veloute-muted);
      line-height: 1.6;
    }

    #shopify-section-{{ section.id }} .veloute-entry-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .veloute-entry {
      position: relative;
      min-height: clamp(430px, 54vw, 690px);
      display: grid;
      align-items: end;
      overflow: hidden;
      background: var(--veloute-panel);
      color: #fff;
      text-decoration: none;
    }

    #shopify-section-{{ section.id }} .veloute-entry img,
    #shopify-section-{{ section.id }} .veloute-product-card img,
    #shopify-section-{{ section.id }} .veloute-category img,
    #shopify-section-{{ section.id }} .veloute-editorial img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform .55s ease;
    }

    #shopify-section-{{ section.id }} .veloute-entry:hover img,
    #shopify-section-{{ section.id }} .veloute-product-card:hover img,
    #shopify-section-{{ section.id }} .veloute-category:hover img,
    #shopify-section-{{ section.id }} .veloute-editorial:hover img {
      transform: scale(1.035);
    }

    #shopify-section-{{ section.id }} .veloute-entry__media,
    #shopify-section-{{ section.id }} .veloute-entry::after {
      position: absolute;
      inset: 0;
    }

    #shopify-section-{{ section.id }} .veloute-entry::after {
      content: "";
      background: linear-gradient(0deg, rgba(0,0,0,.68), rgba(0,0,0,.04) 60%);
    }

    #shopify-section-{{ section.id }} .veloute-entry__content {
      position: relative;
      z-index: 1;
      padding: clamp(22px, 4vw, 42px);
    }

    #shopify-section-{{ section.id }} .veloute-entry__content h3 {
      margin: 0 0 10px;
      font-family: var(--font-heading--family);
      font-size: clamp(2.1rem, 4.2vw, 4.8rem);
      line-height: .96;
      font-weight: 500;
    }

    #shopify-section-{{ section.id }} .veloute-entry__content p {
      margin: 0 0 22px;
      max-width: 420px;
      color: rgba(255,255,255,.82);
      line-height: 1.55;
    }

    #shopify-section-{{ section.id }} .veloute-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: inherit;
      font-size: .78rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      text-decoration: none;
    }

    #shopify-section-{{ section.id }} .veloute-link::after {
      content: "";
      width: 34px;
      height: 1px;
      background: currentColor;
      transition: width .24s ease;
    }

    #shopify-section-{{ section.id }} .veloute-entry:hover .veloute-link::after,
    #shopify-section-{{ section.id }} .veloute-category:hover .veloute-link::after {
      width: 48px;
    }

    #shopify-section-{{ section.id }} .veloute-product-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: clamp(10px, 2vw, 22px);
    }

    #shopify-section-{{ section.id }} .veloute-product-card {
      color: inherit;
      text-decoration: none;
      min-width: 0;
    }

    #shopify-section-{{ section.id }} .veloute-product-card__media,
    #shopify-section-{{ section.id }} .veloute-category__media,
    #shopify-section-{{ section.id }} .veloute-editorial__media {
      position: relative;
      overflow: hidden;
      background: var(--veloute-panel);
      aspect-ratio: 4 / 5;
    }

    #shopify-section-{{ section.id }} .veloute-product-card__info {
      padding-top: 12px;
      display: grid;
      gap: 4px;
    }

    #shopify-section-{{ section.id }} .veloute-product-card__title {
      margin: 0;
      font-size: .98rem;
      font-weight: 500;
      line-height: 1.3;
    }

    #shopify-section-{{ section.id }} .veloute-price {
      color: var(--veloute-muted);
      font-size: .9rem;
    }

    #shopify-section-{{ section.id }} .veloute-category-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .veloute-category {
      color: inherit;
      text-decoration: none;
      display: grid;
      gap: 16px;
    }

    #shopify-section-{{ section.id }} .veloute-category__media {
      aspect-ratio: 1 / 1.18;
    }

    #shopify-section-{{ section.id }} .veloute-category__text {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      border-top: 1px solid var(--veloute-line);
      padding-top: 14px;
    }

    #shopify-section-{{ section.id }} .veloute-category h3 {
      margin: 0;
      font-size: clamp(1.2rem, 2vw, 1.8rem);
      font-weight: 500;
      line-height: 1.1;
    }

    #shopify-section-{{ section.id }} .veloute-editorial {
      display: grid;
      grid-template-columns: minmax(0, .9fr) minmax(0, 1.1fr);
      gap: clamp(22px, 5vw, 72px);
      align-items: center;
      background: var(--veloute-panel);
      padding: clamp(18px, 3.5vw, 44px);
    }

    #shopify-section-{{ section.id }} .veloute-editorial__media {
      aspect-ratio: 4 / 5;
    }

    #shopify-section-{{ section.id }} .veloute-editorial__copy h2 {
      margin: 0 0 18px;
      font-family: var(--font-heading--family);
      font-size: clamp(2.1rem, 4vw, 4.7rem);
      line-height: .98;
      font-weight: 500;
      text-wrap: balance;
    }

    #shopify-section-{{ section.id }} .veloute-editorial__copy p {
      margin: 0 0 24px;
      color: var(--veloute-muted);
      line-height: 1.7;
      max-width: 560px;
    }

    #shopify-section-{{ section.id }} .veloute-service-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1px;
      background: var(--veloute-line);
      border: 1px solid var(--veloute-line);
    }

    #shopify-section-{{ section.id }} .veloute-service {
      background: rgb(var(--color-background-rgb));
      padding: clamp(22px, 3vw, 34px);
      min-height: 180px;
    }

    #shopify-section-{{ section.id }} .veloute-service span {
      display: block;
      color: var(--veloute-muted);
      font-size: .72rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      margin-bottom: 18px;
    }

    #shopify-section-{{ section.id }} .veloute-service h3 {
      margin: 0 0 10px;
      font-size: 1.2rem;
      font-weight: 500;
    }

    #shopify-section-{{ section.id }} .veloute-service p {
      margin: 0;
      color: var(--veloute-muted);
      line-height: 1.55;
    }

    #shopify-section-{{ section.id }} .veloute-final {
      width: min(100% - 32px, 1220px);
      margin: 0 auto clamp(40px, 6vw, 86px);
      padding: clamp(42px, 7vw, 92px);
      background: var(--veloute-dark);
      color: #fff;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .veloute-final h2 {
      margin: 0 auto 18px;
      max-width: 820px;
      font-family: var(--font-heading--family);
      font-size: clamp(2.4rem, 5.8vw, 6.2rem);
      line-height: .92;
      font-weight: 500;
      text-wrap: balance;
    }

    #shopify-section-{{ section.id }} .veloute-final p {
      margin: 0 auto;
      max-width: 560px;
      color: rgba(255,255,255,.72);
      line-height: 1.65;
    }

    #shopify-section-{{ section.id }} .veloute-final .veloute-actions {
      justify-content: center;
    }

    @media screen and (max-width: 989px) {
      #shopify-section-{{ section.id }} .veloute-hero__inner,
      #shopify-section-{{ section.id }} .veloute-editorial {
        grid-template-columns: 1fr;
      }

      #shopify-section-{{ section.id }} .veloute-hero__aside {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      #shopify-section-{{ section.id }} .veloute-proof,
      #shopify-section-{{ section.id }} .veloute-product-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .veloute-hero {
        min-height: 88svh;
      }

      #shopify-section-{{ section.id }} .veloute-hero__inner {
        width: min(100% - 28px, 1220px);
        padding-top: 92px;
      }

      #shopify-section-{{ section.id }} .veloute-actions,
      #shopify-section-{{ section.id }} .veloute-button {
        width: 100%;
      }

      #shopify-section-{{ section.id }} .veloute-hero__aside,
      #shopify-section-{{ section.id }} .veloute-proof,
      #shopify-section-{{ section.id }} .veloute-entry-grid,
      #shopify-section-{{ section.id }} .veloute-category-grid,
      #shopify-section-{{ section.id }} .veloute-service-grid {
        grid-template-columns: 1fr;
      }

      #shopify-section-{{ section.id }} .veloute-section-head {
        display: grid;
      }

      #shopify-section-{{ section.id }} .veloute-product-grid {
        gap: 18px 10px;
      }

      #shopify-section-{{ section.id }} .veloute-entry {
        min-height: 430px;
      }

      #shopify-section-{{ section.id }} .veloute-final {
        width: min(100% - 28px, 1220px);
        padding: 42px 18px;
      }
    }
  </style>

  <div class="veloute-hero">
    <div class="veloute-hero__media" aria-hidden="true">
      {% if section.settings.hero_video != blank %}
        {{ section.settings.hero_video | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
      {% elsif section.settings.hero_image != blank %}
        {{ section.settings.hero_image | image_url: width: 2400 | image_tag: loading: 'eager', fetchpriority: 'high', sizes: '100vw' }}
      {% elsif fallback_product.featured_image != blank %}
        {{ fallback_product.featured_image | image_url: width: 2400 | image_tag: loading: 'eager', fetchpriority: 'high', sizes: '100vw' }}
      {% else %}
        <div class="veloute-hero__placeholder"></div>
      {% endif %}
    </div>

    <div class="veloute-hero__inner">
      <div>
        <p class="veloute-kicker">{{ section.settings.hero_kicker }}</p>
        <h1>{{ section.settings.hero_heading }}</h1>
        <p class="veloute-hero__copy">{{ section.settings.hero_text }}</p>
        <div class="veloute-actions">
          <a class="veloute-button veloute-button--light" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
          <a class="veloute-button veloute-button--ghost" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
        </div>
      </div>

      <div class="veloute-hero__aside">
        <div><strong>01 Curated</strong>Accessoires mit ruhiger Silhouette und starkem Finish.</div>
        <div><strong>02 Everyday</strong>Schmuck, der nicht laut sein muss, um zu wirken.</div>
        <div><strong>03 Ready</strong>Schnell auswählbar nach Anlass, Stil und Geschenkidee.</div>
      </div>
    </div>
  </div>

  <div class="veloute-band veloute-proof" aria-label="Shop Vorteile">
    <div class="veloute-proof__item"><span>Versand</span><strong>Kostenlos ab 49 €</strong></div>
    <div class="veloute-proof__item"><span>Auswahl</span><strong>Kuratiert statt beliebig</strong></div>
    <div class="veloute-proof__item"><span>Geschenke</span><strong>Elegant verpackt</strong></div>
    <div class="veloute-proof__item"><span>Support</span><strong>Persönlich erreichbar</strong></div>
  </div>

  <div class="veloute-band">
    <div class="veloute-section-head">
      <h2>Ein Shop für Looks, die fertig wirken.</h2>
      <p>Veloute führt Kundinnen und Kunden schneller zu dem Accessoire, das ein Outfit komplett macht: klare Einstiege, starke Bilder, direkte Wege zu den wichtigsten Kollektionen.</p>
    </div>

    <div class="veloute-entry-grid">
      {% render 'veloute-home-entry', collection: womens_collection, title: 'Damen', text: 'Feine Schmuckstücke, Taschen-Details und Accessoires für elegante Alltagslooks.', fallback_url: '/collections/damen-accessoires' %}
      {% render 'veloute-home-entry', collection: mens_collection, title: 'Herren', text: 'Reduzierte Details, klare Formen und Accessoires mit ruhiger Präsenz.', fallback_url: '/collections/herren-accessoires' %}
    </div>
  </div>

  {% if highlights_collection != blank %}
    <div class="veloute-band">
      <div class="veloute-section-head">
        <h2>Highlights, die sofort funktionieren.</h2>
        <p>Eine konzentrierte Auswahl für Kundinnen und Kunden, die schnell etwas Schönes finden wollen.</p>
      </div>

      <div class="veloute-product-grid">
        {% for product in highlights_collection.products limit: 8 %}
          <a class="veloute-product-card" href="{{ product.url }}">
            <div class="veloute-product-card__media">
              {% if product.featured_image != blank %}
                {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 25vw, 50vw', alt: product.title }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag }}
              {% endif %}
            </div>
            <div class="veloute-product-card__info">
              <p class="veloute-product-card__title">{{ product.title }}</p>
              <span class="veloute-price">{{ product.price | money }}</span>
            </div>
          </a>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <div class="veloute-band">
    <div class="veloute-section-head">
      <h2>Nach Stil shoppen.</h2>
      <p>Die wichtigsten Kategorien sind jetzt visuell klarer getrennt und laden zum Stöbern ein.</p>
    </div>

    <div class="veloute-category-grid">
      {% render 'veloute-home-category', collection: necklace_collection, title: 'Halsketten', fallback_url: '/collections/halsketten' %}
      {% render 'veloute-home-category', collection: bracelet_collection, title: 'Armbänder', fallback_url: '/collections/armbaender' %}
      {% render 'veloute-home-category', collection: keychain_collection, title: 'Schlüsselanhänger', fallback_url: '/collections/schlusselanhanger' %}
    </div>
  </div>

  <div class="veloute-band">
    <a class="veloute-editorial" href="{{ section.settings.primary_link }}">
      <div class="veloute-editorial__media">
        {% if fallback_product.featured_image != blank %}
          {{ fallback_product.featured_image | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 45vw, 100vw', alt: fallback_product.title }}
        {% else %}
          {{ 'product-2' | placeholder_svg_tag }}
        {% endif %}
      </div>
      <div class="veloute-editorial__copy">
        <p class="veloute-kicker">Veloute Edit</p>
        <h2>Accessoires als kleines Statement.</h2>
        <p>Die Startseite verkauft nicht nur Produkte, sondern Orientierung: Weniger Auswahlstress, mehr kuratierte Momente und ein Look, der hochwertig genug für eine Boutique wirkt.</p>
        <span class="veloute-link">Kollektion entdecken</span>
      </div>
    </a>
  </div>

  <div class="veloute-band veloute-service-grid">
    <div class="veloute-service"><span>Beratung</span><h3>Leicht zu kombinieren</h3><p>Texte und Wege sind auf Outfit, Geschenk und Anlass ausgerichtet.</p></div>
    <div class="veloute-service"><span>Wertigkeit</span><h3>Ruhige Premium-Optik</h3><p>Große Bildflächen, klare Typografie und weniger visuelles Rauschen.</p></div>
    <div class="veloute-service"><span>Conversion</span><h3>Schnellere Entscheidungen</h3><p>Damen, Herren, Highlights und Kategorien sind direkt im ersten Flow erreichbar.</p></div>
  </div>

  <div class="veloute-final">
    <p class="veloute-kicker">Veloute Boutique</p>
    <h2>Das richtige Detail macht den ganzen Look.</h2>
    <p>Entdecke Schmuck und Accessoires, die sich leicht schenken lassen und jeden Tag hochwertig wirken.</p>
    <div class="veloute-actions">
      <a class="veloute-button veloute-button--light" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
