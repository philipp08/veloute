{% liquid
  assign button_link = section.settings.button_link
  if button_link == blank
    assign button_link = routes.all_products_collection_url
  endif
%}

<section class="veloute-editorial-banner color-{{ section.settings.color_scheme }}">
  <style>
    #shopify-section-{{ section.id }} .veloute-editorial-banner {
      background: var(--color-background);
      color: var(--color-foreground);
    }

    #shopify-section-{{ section.id }} .veloute-editorial-banner__inner {
      width: {% if section.settings.full_width %}100%{% else %}min(100% - 32px, 1320px){% endif %};
      margin: 0 auto;
      padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .veloute-editorial-banner__panel {
      position: relative;
      min-height: {{ section.settings.height }}px;
      display: grid;
      align-items: {{ section.settings.vertical_alignment }};
      overflow: hidden;
      color: #fff;
      background: #111;
      isolation: isolate;
    }

    #shopify-section-{{ section.id }} .veloute-editorial-banner__media,
    #shopify-section-{{ section.id }} .veloute-editorial-banner__media img,
    #shopify-section-{{ section.id }} .veloute-editorial-banner__media video,
    #shopify-section-{{ section.id }} .veloute-editorial-banner__media svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    #shopify-section-{{ section.id }} .veloute-editorial-banner__media {
      z-index: -2;
    }

    #shopify-section-{{ section.id }} .veloute-editorial-banner__media img,
    #shopify-section-{{ section.id }} .veloute-editorial-banner__media video,
    #shopify-section-{{ section.id }} .veloute-editorial-banner__media svg {
      object-fit: cover;
    }

    #shopify-section-{{ section.id }} .veloute-editorial-banner__panel::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      background: linear-gradient(90deg, rgb(0 0 0 / .62), rgb(0 0 0 / .22) 56%, rgb(0 0 0 / .06));
    }

    #shopify-section-{{ section.id }} .veloute-editorial-banner__content {
      width: min(100% - 32px, 1320px);
      margin: 0 auto;
      padding: clamp(34px, 6vw, 84px) 0;
      text-align: {{ section.settings.text_alignment }};
      display: grid;
      justify-items: {% if section.settings.text_alignment == 'center' %}center{% elsif section.settings.text_alignment == 'right' %}end{% else %}start{% endif %};
    }

    #shopify-section-{{ section.id }} .veloute-editorial-banner__eyebrow {
      margin: 0 0 16px;
      font-size: .72rem;
      letter-spacing: .13em;
      line-height: 1.3;
      text-transform: uppercase;
      color: rgb(255 255 255 / .78);
    }

    #shopify-section-{{ section.id }} .veloute-editorial-banner__content h2 {
      margin: 0;
      max-width: 780px;
      font-family: var(--font-heading--family);
      font-size: clamp(2.35rem, 5.3vw, 6rem);
      line-height: .94;
      font-weight: 500;
      text-wrap: balance;
    }

    #shopify-section-{{ section.id }} .veloute-editorial-banner__content p {
      margin: 20px 0 0;
      max-width: 560px;
      color: rgb(255 255 255 / .78);
      line-height: 1.65;
    }

    #shopify-section-{{ section.id }} .veloute-editorial-banner__button {
      min-height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-top: 30px;
      padding: 14px 22px;
      color: #111;
      background: #fff;
      text-decoration: none;
      font-size: .78rem;
      letter-spacing: .1em;
      line-height: 1.2;
      text-transform: uppercase;
      transition: transform .22s ease;
    }

    #shopify-section-{{ section.id }} .veloute-editorial-banner__button:hover {
      transform: translateY(-2px);
    }

    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .veloute-editorial-banner__inner {
        width: {% if section.settings.full_width %}100%{% else %}min(100% - 28px, 1320px){% endif %};
      }

      #shopify-section-{{ section.id }} .veloute-editorial-banner__panel {
        min-height: {{ section.settings.height_mobile }}px;
      }

      #shopify-section-{{ section.id }} .veloute-editorial-banner__content {
        width: min(100% - 28px, 1320px);
      }

      #shopify-section-{{ section.id }} .veloute-editorial-banner__button {
        width: 100%;
      }
    }
  </style>

  <div class="veloute-editorial-banner__inner">
    <div class="veloute-editorial-banner__panel">
      <div class="veloute-editorial-banner__media" aria-hidden="true">
        {% if section.settings.video != blank %}
          {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
        {% elsif section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'lazy', sizes: '100vw' }}
        {% else %}
          {{ 'hero-apparel-2' | placeholder_svg_tag }}
        {% endif %}
      </div>

      <div class="veloute-editorial-banner__content">
        {% if section.settings.eyebrow != blank %}
          <p class="veloute-editorial-banner__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <p>{{ section.settings.text }}</p>
        {% endif %}
        {% if section.settings.button_label != blank %}
          <a class="veloute-editorial-banner__button" href="{{ button_link }}">{{ section.settings.button_label }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Veloute banner",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Desktop height",
      "min": 360,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 640
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Mobile height",
      "min": 320,
      "max": 760,
      "step": 20,
      "unit": "px",
      "default": 520
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Content vertical position",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Kollektion Privé"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ein Banner für eine klare Kollektion."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Setze hier eine Kollektion, einen Drop oder einen saisonalen Fokus prominent in Szene."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Jetzt entdecken"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Veloute banner"
    }
  ]
}
{% endschema %}
